<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>가나비 AI 에디터</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <style>
        /* ── 수현 님의 원본 디자인 보존 ── */
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700;900&display=swap');
        
        body {
            font-family: 'Noto Sans KR', sans-serif;
            background-color: #f5f2e8;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .container {
            background: white;
            padding: 60px 40px;
            border-radius: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            text-align: center;
            width: 90%;
            max-width: 800px;
        }

        h1 { font-size: 3rem; font-weight: 900; color: #333; margin-bottom: 20px; }
        p { color: #666; margin-bottom: 30px; font-size: 1.1rem; }
        
        #file-input { margin: 20px 0; }
        #file-status { margin-top: 15px; color: #5a8a3c; font-weight: 700; min-height: 24px; }
        
        .btn-generate {
            background-color: #c8ddb0;
            color: #4a7a32;
            border: none;
            padding: 15px 40px;
            border-radius: 12px;
            font-size: 1.2rem;
            font-weight: 700;
            cursor: pointer;
            margin-top: 20px;
            transition: 0.2s;
        }
        .btn-generate:disabled { background-color: #eee; color: #aaa; cursor: not-allowed; }

        /* 결과 화면 설정 */
        #test-screen {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: white;
            padding: 40px;
            overflow-y: auto;
            flex-direction: column;
            align-items: center;
        }
        .word-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 20px;
            margin-top: 30px;
            width: 100%;
        }
        .word-item {
            border: 2px solid #c8ddb0;
            padding: 20px;
            border-radius: 15px;
            font-size: 1.4rem;
            font-weight: 700;
            text-align: center;
        }
    </style>
</head>
<body>

    <div class="container" id="main-screen">
        <h1>가나비 AI 에디터</h1>
        <p>엑셀 어휘표를 기반으로 <b>반별 랜덤 시험</b>을 생성합니다.</p>
        
        <input type="file" id="file-input" accept=".xlsx,.xls">
        <div id="file-status"></div>
        
        <button id="generate-btn" class="btn-generate" disabled onclick="generateTest()">수행평가 생성</button>
    </div>

    <div id="test-screen">
        <h1>일본어 단어 테스트</h1>
        <div class="word-grid" id="word-grid"></div>
        <button class="btn-generate" onclick="window.print()" style="margin-top:40px;">인쇄하기</button>
        <button onclick="location.reload()" style="margin-top:10px; background:none; border:none; color:#666; cursor:pointer;">다시 만들기</button>
    </div>

    <script>
        let wordData = { sang: [], jung: [], ha: [] };

        // 1. 엑셀 파일 읽기
        document.getElementById('file-input').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                const data = new Uint8Array(e.target.result);
                const workbook = XLSX.read(data, {type: 'array'});
                const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
                const json = XLSX.utils.sheet_to_json(firstSheet, {header: 1});

                wordData = { sang: [], jung: [], ha: [] };
                
                // 2행부터 데이터 추출 (A:상, B:중, C:하)
                json.slice(1).forEach(row => {
                    if(row[0]) wordData.sang.push(row[0]);
                    if(row[1]) wordData.jung.push(row[1]);
                    if(row[2]) wordData.ha.push(row[2]);
                });

                document.getElementById('file-status').innerText = `✅ ${file.name} 준비 완료!`;
                document.getElementById('generate-btn').disabled = false;
            };
            reader.readAsArrayBuffer(file);
        });

        // 2. 랜덤 추출 및 화면 전환
        function generateTest() {
            const shuffle = (arr) => [...arr].sort(() => Math.random() - 0.5);
            
            // 난이도별 추출 (상1, 중2, 하1 예시)
            const final = [
                ...shuffle(wordData.sang).slice(0, 1),
                ...shuffle(wordData.jung).slice(0, 2),
                ...shuffle(wordData.ha).slice(0, 1)
            ];

            const grid = document.getElementById('word-grid');
            grid.innerHTML = final.map((word, i) => `
                <div class="word-item">
                    <span style="font-size:0.8rem; color:#999;">${i+1}</span><br>${word}
                </div>
            `).join('');

            document.getElementById('main-screen').style.display = 'none';
            document.getElementById('test-screen').style.display = 'flex';
        }
    </script>
</body>
</html>
