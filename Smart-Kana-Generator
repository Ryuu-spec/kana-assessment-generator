// --- 기존 initSavedBanner() 함수 아래에 이어서 붙여넣으세요 ---

function loadSavedData() {
  try {
    const saved = localStorage.getItem('gana_wordData');
    const savedName = localStorage.getItem('gana_fileName');
    if (!saved) return;
    wordData = JSON.parse(saved);
    
    // 파일 정보 요약 표시
    const status = document.getElementById('file-status');
    status.innerText = `✅ 저장된 파일(${savedName}) 로드 완료`;
    document.getElementById('generate-btn').disabled = false;
    document.getElementById('file-replace-row').style.display = 'block';
  } catch(e) {
    console.error("데이터 로드 실패:", e);
  }
}

function clearSavedData() {
  localStorage.removeItem('gana_wordData');
  localStorage.removeItem('gana_fileName');
  document.getElementById('saved-banner').style.display = 'none';
  document.getElementById('file-status').innerText = "";
  document.getElementById('generate-btn').disabled = true;
}

// ── 엑셀 파일 처리 (A:상, B:중, C:하) ──
document.getElementById('file-input').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = function(e) {
    const data = new Uint8Array(e.target.result);
    const workbook = XLSX.read(data, {type: 'array'});
    const sheetName = workbook.SheetNames[0];
    const sheet = workbook.Sheets[sheetName];
    const json = XLSX.utils.sheet_to_json(sheet, {header: 1});

    wordData = { sang: [], jung: [], ha: [] };
    
    // 2행부터 데이터 추출 (1행은 제목행 가정)
    json.slice(1).forEach(row => {
      if(row[0]) wordData.sang.push(row[0]);
      if(row[1]) wordData.jung.push(row[1]);
      if(row[2]) wordData.ha.push(row[2]);
    });

    localStorage.setItem('gana_wordData', JSON.stringify(wordData));
    localStorage.setItem('gana_fileName', file.name);
    
    document.getElementById('file-status').innerText = `✅ ${file.name} 업로드 완료`;
    document.getElementById('generate-btn').disabled = false;
    document.getElementById('file-replace-row').style.display = 'block';
  };
  reader.readAsArrayBuffer(file);
});

// ── 화면 전환 로직 ──
function showScreen(id) {
  document.querySelectorAll('.screen, #test-screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.screen, #test-screen').forEach(s => s.style.display = 'none');
  const target = document.getElementById(id);
  target.style.display = (id === 'test-screen') ? 'flex' : 'flex';
  target.classList.add('active');
}

function goToUpload() {
  if (selectedFrontRows.length === 0) {
    document.getElementById('q1-warning').style.display = 'block';
    return;
  }
  showScreen('upload-screen');
  initSavedBanner();
}

function goToSettings() { showScreen('settings-screen'); }

// ── 핵심: 난이도별 랜덤 추출 및 시험지 생성 ──
function generateTest() {
  // 1. 1번 문제 행 결정
  const currentRows = ROWS_MAP[currentScript] || ALL_ROWS;
  const row1 = selectedFrontRows[Math.floor(Math.random() * selectedFrontRows.length)];
  const secondPool = currentRows.filter(r => r !== row1);
  const row2 = secondPool[Math.floor(Math.random() * secondPool.length)];

  document.getElementById('q1-badges-inline').innerHTML = 
    `<span class="row-badge-inline">${row1}</span> <span class="row-badge-inline">${row2}</span>`;

  // 2. 2번 문제 단어 추출 (상, 중, 하)
  const shuffle = (arr) => [...arr].sort(() => Math.random() - 0.5);
  
  const selectedWords = [
    ...shuffle(wordData.sang).slice(0, counts.sang),
    ...shuffle(wordData.jung).slice(0, counts.jung),
    ...shuffle(wordData.ha).slice(0, counts.ha)
  ];

  // 3. 결과 렌더링
  const grid = document.getElementById('q2-word-grid');
  grid.innerHTML = selectedWords.map((word, i) => `
    <div class="word-card-wrap">
      <div class="word-num">${i + 1}</div>
      <div class="word-card"><div class="word-korean">${word}</div></div>
    </div>
  `).join('');

  showScreen('test-screen');
}

function revealTest() {
  window.print(); // 수행평가지 출력을 위해 프린트창 실행
}
