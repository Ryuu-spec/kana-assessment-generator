<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<title>가나비 — AI 랜덤 디지털 수행평가</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  /* 신수현 님 원본 레이아웃 및 디자인 100% 준수 */
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700;900&display=swap');
  :root { --bg: #f5f2e8; --card: #ffffff; --green-point: #c8ddb0; --green-dark: #5a8a3c; }
  body { font-family: 'Noto Sans KR', sans-serif; background: var(--bg); margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
  
  .screen { display: none; width: 100%; max-width: 900px; padding: 20px; flex-direction: column; align-items: center; }
  .screen.active { display: flex !important; }

  .title { font-size: 2.5rem; font-weight: 900; margin-bottom: 40px; color: #333; }
  .test-card { background: var(--card); border-radius: 25px; padding: 40px; width: 100%; margin-bottom: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
  .q-num { background: var(--green-point); color: var(--green-dark); width: 40px; height: 40px; display: inline-flex; justify-content: center; align-items: center; border-radius: 8px; font-weight: 900; margin-right: 15px; }
  .q-text { font-size: 1.8rem; font-weight: 700; color: #444; vertical-align: middle; }
  
  /* 랜덤 단어 배치 그리드 */
  .word-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 30px; }
  .word-box { border: 2px solid var(--green-point); border-radius: 20px; padding: 25px; display: flex; flex-direction: column; align-items: center; background: #fff; }
  
  .answer-input { width: 80%; padding: 10px; border: none; border-bottom: 3px solid var(--green-point); text-align: center; font-size: 1.5rem; outline: none; margin-top: 15px; }
  
  .btn-main { background: var(--green-point); border: none; border-radius: 12px; padding: 15px 60px; font-size: 1.2rem; font-weight: 700; color: var(--green-dark); cursor: pointer; transition: 0.3s; }
  .btn-main:hover { background: var(--green-dark); color: white; }

  .class-info { margin-bottom: 20px; font-size: 1.2rem; font-weight: 700; color: var(--green-dark); }
</style>
</head>
<body>

<div id="settings-screen" class="screen active">
  <div class="test-card" style="text-align:center;">
    <h1 class="title">가나비 AI 에디터</h1>
    <p>엑셀 어휘표를 기반으로 <b>반별 랜덤 시험</b>을 생성합니다.</p>
    <div style="margin:20px 0;">
      <input type="file" id="excel-file" accept=".xlsx" onchange="processAI(this)">
    </div>
    <div id="file-status" style="margin-bottom:20px; color:var(--green-dark); font-weight:bold;"></div>
    <div id="class-select-area" style="display:none;">
      <input type="text" id="class-name" placeholder="학급 입력 (예: 1반)" style="padding:10px; border-radius:8px; border:1px solid #ccc; margin-right:10px;">
      <button class="btn-main" onclick="generateRandomTest()">랜덤 시험지 생성</button>
    </div>
  </div>
</div>

<div id="test-screen" class="screen">
  <div class="class-info" id="display-class"></div>
  <h1 class="title">디지털 수행평가</h1>
  <div class="test-card">
    <div class="q-num">1</div>
    <span class="q-text">다음 단어의 일본어를 정확히 입력하세요. (AI 채점)</span>
    <div class="word-grid" id="q2-word-area"></div>
  </div>
  <button class="btn-main" onclick="gradeTest()">제출 및 AI 자동채점</button>
</div>

<div id="result-screen" class="screen">
  <div class="test-card" style="text-align:center;">
    <h1 class="title">평가 리포트</h1>
    <div id="final-score" style="font-size:4rem; font-weight:900; color:var(--green-dark); margin:20px 0;">0점</div>
    <div id="result-details" style="text-align:left; max-height:300px; overflow-y:auto; padding:10px; border-top:1px solid #eee;"></div>
    <button class="btn-main" style="margin-top:30px;" onclick="location.reload()">새 학급 시험 생성</button>
  </div>
</div>

<script>
let aiWordPool = { sang: [], jung: [], ha: [] };
let currentTestWords = [];

// [AI 어휘 분석] 2022 개정 교육과정 기준 적용
function analyzeLevel(word) {
  if (/[ゃゅょャュョっッー]/.test(word)) return 'sang'; // 요음, 촉음, 장음
  if (word.length >= 3 || /[が-ぼぱ-ぽ]/.test(word)) return 'jung'; // 탁음/길이
  return 'ha';
}

function processAI(input) {
  const reader = new FileReader();
  reader.onload = (e) => {
    const data = new Uint8Array(e.target.result);
    const wb = XLSX.read(data, {type: 'array'});
    const json = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], {header: 1});
    
    aiWordPool = { sang: [], jung: [], ha: [] };
    json.forEach(row => {
      if (row[0] && row[1]) {
        const word = row[0].toString().trim();
        const mean = row[1].toString().trim();
        const lv = analyzeLevel(word);
        aiWordPool[lv].push({ ja: word, ko: mean });
      }
    });
    document.getElementById('file-status').textContent = `AI 분석 완료 (상:${aiWordPool.sang.length}, 중:${aiWordPool.jung.length}, 하:${aiWordPool.ha.length})`;
    document.getElementById('class-select-area').style.display = 'block';
  };
  reader.readAsArrayBuffer(input.files[0]);
}

// [핵심] 반마다 랜덤으로 문제를 뽑아내는 함수
function generateRandomTest() {
  const className = document.getElementById('class-name').value || "수행평가";
  document.getElementById('display-class').textContent = `현재 학급: ${className}`;
  
  // 난이도별 무작위 추출 (중복 방지)
  const getRandom = (arr, n) => arr.sort(() => .5 - Math.random()).slice(0, n);
  
  currentTestWords = [
    ...getRandom(aiWordPool.sang, 1),
    ...getRandom(aiWordPool.jung, 2),
    ...getRandom(aiWordPool.ha, 1)
  ].sort(() => .5 - Math.random()); // 배치 순서까지 랜덤화

  const area = document.getElementById('q2-word-area');
  area.innerHTML = currentTestWords.map((w, i) => `
    <div class="word-box">
      <span style="font-size:1.4rem; font-weight:700;">${w.ko}</span>
      <input type="text" class="answer-input" id="ans-${i}" placeholder="정답 입력">
    </div>
  `).join('');
  
  showScreen('test-screen');
}

function gradeTest() {
  let score = 0;
  let html = '';
  currentTestWords.forEach((w, i) => {
    const userAns = document.getElementById(`ans-${i}`).value.trim();
    const isCorrect = userAns === w.ja;
    if (isCorrect) score += 25;
    html += `<p>${i+1}. ${w.ko} | 입력: ${userAns || '미입력'} | 정답: ${w.ja} [${isCorrect ? '✅' : '❌'}]</p>`;
  });
  document.getElementById('final-score').textContent = score + '점';
  document.getElementById('result-details').innerHTML = html;
  showScreen('result-screen');
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
</script>
</body>
</html>
