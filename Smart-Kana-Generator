    </div>
    <!-- 엑셀 업로드 존 -->
    <div class="upload-zone" id="upload-zone"
         onclick="document.getElementById('xl-input').click()"
         ondragover="event.preventDefault();this.classList.add('drag-active')"
         ondragleave="this.classList.remove('drag-active')"
         ondrop="this.classList.remove('drag-active');handleXlDrop(event)">
      <div class="upload-icon">📂</div>
      <div class="upload-main-txt">엑셀 파일을 여기에 끌어다 놓거나 클릭하여 업로드</div>
      <div class="upload-sub-txt">Hands-on interactive feel · .xlsx / .xls</div>
      <div class="upload-format-txt">A열 = 상 &nbsp;·&nbsp; B열 = 중 &nbsp;·&nbsp; C열 = 하</div>
    </div>
    <input type="file" id="xl-input" accept=".xlsx,.xls" style="display:none" onchange="handleXlFile(this.files[0])">
    <!-- 등록 수 & 전체 삭제 -->
    <div class="upload-zone-footer">
      <span class="word-count-badge">등록 <b id="word-count">0</b>개</span>
      <button class="btn btn-ol" style="font-size:.68rem;padding:4px 10px;" onclick="clearWords()">전체 삭제</button>
    </div>
  </div>
</div>

