<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>가나비 AI — 지능형 평가 엔진</title>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700;900&display=swap');
  :root { --bg: #f8f9fa; --green-dark: #2d5a27; --green-light: #e8f5e9; --warn: #fff3e0; --error: #ffebee; }
  body { font-family: 'Noto Sans KR', sans-serif; background: var(--bg); margin: 0; }
  .screen { display: none; flex-direction: column; align-items: center; padding: 40px 20px; min-height: 100vh; }
  .screen.active { display: flex; }
  .card { background: white; border-radius: 20px; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); width: 100%; max-width: 900px; text-align: center; }
  
  /* 엑셀 스타일 테이블 */
  .excel-table { width: 100%; border-collapse: collapse; margin-top: 20px; table-layout: fixed; }
  .excel-table th { background: #f1f3f4; border: 1px solid #dadce0; padding: 10px; font-size: 0.9rem; }
  .excel-table td { border: 1px solid #dadce0; padding: 12px; height: 40px; font-size: 0.85rem; position: relative; }
  
  /* AI 분석 상태 컬러 */
  .status-match { background-color: #e8f5e9; } /* 일치 (초록) */
  .status-diff { background-color: #fff9c4; border: 2px solid #fbc02d !important; } /* 주의 (노랑) */
  .ai-tip { font-size: 0.7rem; color: #d32f2f; display: block; margin-top: 4px; font-weight: bold; }

  .btn-next { background: var(--green-dark); color: white; border: none; padding: 15px 40px; border-radius: 30px; font-weight: bold; cursor: pointer; margin-top: 30px; font-size: 1rem; }
  .btn-next:disabled { background: #ccc; }
</style>
</head>
<body>

<div id="select-screen" class="screen active">
  <div class="card">
    <h1 style="color:var(--green-dark); font-weight:900;">가나비 AI</h1>
    <p>AI 음절 분석 엔진 기반 수행평가 생성 도구</p>
    <button class="btn-next" onclick="showScreen('settings-screen')">평가 생성 시작하기</button>
  </div>
</div>

<div id="settings-screen" class="screen">
  <div class="card">
    <h2>평가 설정</h2>
    <div style="margin: 20px 0;">상: <input type="number" id="cnt-sang" value="1" style="width:40px"> 중: <input type="number" id="cnt-jung" value="2" style="width:40px"> 하: <input type="number" id="cnt-ha" value="1" style="width:40px"></div>
    <button class="btn-next" onclick="showScreen('upload-screen')">다음: 데이터 업로드</button>
  </div>
</div>

<div id="upload-screen" class="screen">
  <div class="card" style="max-width: 800px;">
    <h2>데이터 AI 검수</h2>
    <p style="font-size: 0.9rem; color: #666;">교사가 분류한 데이터를 AI가 정밀 분석 중입니다. 색상 표시를 확인하세요.</p>
    
    <input type="file" id="file-input" accept=".xlsx, .xls, .csv" style="display:none" onchange="handleExcel(event)">
    <button class="btn-next" style="background:#eee; color:#333; margin-bottom: 20px;" onclick="document.getElementById('file-input').click()">📁 엑셀/CSV 파일 선택</button>

    <div id="table-container" style="overflow-x: auto;">
      <table class="excel-table">
        <thead>
          <tr>
            <th>상 (A열)</th>
            <th>중 (B열)</th>
            <th>하 (C열)</th>
          </tr>
        </thead>
        <tbody id="excel-body">
          <tr><td colspan="3" style="color:#999;">파일을 업로드하면 이곳에 분석 결과가 표시됩니다.</td></tr>
        </tbody>
      </table>
    </div>

    <button id="generate-btn" class="btn-next" disabled onclick="generateTest()">시험지 생성하기</button>
  </div>
</div>

<div id="test-screen" class="screen">
  <div id="print-area" style="background:white; padding:40px; width:100%; max-width:700px; border:1px solid #000;">
    <h1 style="text-align:center;">일본어 수행평가</h1>
    <div id="out-grid" style="display:grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 30px;"></div>
  </div>
  <button class="btn-next" onclick="window.print()">인쇄하기</button>
</div>

<script>
const wordDB = {
  "병원": "びょういん", "학교": "がっこう", "도서관": "としょかん", "우체국": "ゆうびんきょく", "고등학교": "こうとうがっこう",
  "모자": "ぼ우し", "우표": "きって", "수학": "すうがく", "공원": "こうえん", "오후": "고ご", "야구": "やきゅう", "가족": "かぞく",
  "가방": "かばん", "책": "ほん", "의자": "いす", "창문": "まど", "산책": "さんぽ", "책상": "つくえ"
};

let uploadedData = { sang: [], jung: [], ha: [] };

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function handleExcel(e) {
  const file = e.target.files[0];
  const reader = new FileReader();
  reader.onload = function(evt) {
    const data = evt.target.result;
    const workbook = XLSX.read(data, {type: 'binary'});
    const sheet = workbook.Sheets[workbook.SheetNames[0]];
    const rows = XLSX.utils.sheet_to_json(sheet, {header: 1, defval: ""});

    const body = document.getElementById('excel-body');
    body.innerHTML = "";
    uploadedData = { sang: [], jung: [], ha: [] };

    // 엑셀 뷰어 생성 및 AI 분석
    rows.slice(1).forEach(row => {
      const tr = document.createElement('tr');
      [0, 1, 2].forEach(colIdx => {
        const td = document.createElement('td');
        const word = row[colIdx] ? String(row[colIdx]).trim() : "";
        td.textContent = word;

        if(word) {
          const userLevel = colIdx === 0 ? 'sang' : (colIdx === 1 ? 'jung' : 'ha');
          const kana = wordDB[word];
          
          if(kana) {
            const mora = kana.replace(/[ゃゅょ]/g, "").length;
            const aiLevel = mora >= 4 ? 'sang' : (mora === 3 ? 'jung' : 'ha');

            if(aiLevel === userLevel) {
              td.className = "status-match"; // 일치하면 초록색
            } else {
              td.className = "status-diff"; // 다르면 노란색 하이라이트
              const tip = document.createElement('span');
              tip.className = "ai-tip";
              tip.textContent = `AI추천: ${aiLevel === 'sang' ? '상' : aiLevel === 'jung' ? '중' : '하'} (${mora}박)`;
              td.appendChild(tip);
            }
            uploadedData[userLevel].push(word);
          } else {
            uploadedData[userLevel].push(word); // DB에 없으면 그대로
          }
        }
        tr.appendChild(td);
      });
      body.appendChild(tr);
    });
    document.getElementById('generate-btn').disabled = false;
  };
  reader.readAsBinaryString(file);
}

function generateTest() {
  const sCnt = parseInt(document.getElementById('cnt-sang').value);
  const jCnt = parseInt(document.getElementById('cnt-jung').value);
  const hCnt = parseInt(document.getElementById('cnt-ha').value);

  const final = [
    ...uploadedData.sang.sort(() => 0.5 - Math.random()).slice(0, sCnt),
    ...uploadedData.jung.sort(() => 0.5 - Math.random()).slice(0, jCnt),
    ...uploadedData.ha.sort(() => 0.5 - Math.random()).slice(0, hCnt)
  ];

  const grid = document.getElementById('out-grid');
  grid.innerHTML = final.map((w, i) => `<div style="border:1px solid #ccc; padding:15px;">${i+1}. ${w}</div>`).join('');
  showScreen('test-screen');
}
</script>
</body>
</html>
