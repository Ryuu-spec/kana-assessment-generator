/* ── 신수현 님의 원본 스크립트 기반: 랜덤 로직 완결본 ── */

// 1. 문제 생성하기 (generateTest) 함수
function generateTest() {
  // 1번 문제: 선택된 행들 중 1개 랜덤 + 나머지 중 1개 랜덤
  const currentRows = ROWS_MAP[currentScript] || ALL_ROWS;
  
  // 첫 번째 행: 사용자가 버튼으로 선택한 리스트(selectedFrontRows) 중 1개 랜덤 추출
  const firstRowIdx = Math.floor(Math.random() * selectedFrontRows.length);
  const row1 = selectedFrontRows[firstRowIdx];

  // 두 번째 행: 전체 행 중 첫 번째 행을 제외하고 1개 랜덤 추출
  const secondPool = currentRows.filter(r => r !== row1);
  const row2 = secondPool[Math.floor(Math.random() * secondPool.length)];

  // 1번 문제 UI 업데이트 (님의 row-badge-inline 스타일 유지)
  const q1Badges = document.getElementById('q1-badges-inline');
  q1Badges.innerHTML = `
    <span class="row-badge-inline">${row1}</span>
    <span class="row-badge-inline">${row2}</span>
  `;

  // 2번 문제: 엑셀에서 불러온 wordData를 난이도별(sang, jung, ha) 셔플 후 개수만큼 추출
  const finalWords = [
    ...shuffleArray(wordData.sang).slice(0, counts.sang),
    ...shuffleArray(wordData.jung).slice(0, counts.jung),
    ...shuffleArray(wordData.ha).slice(0, counts.ha)
  ];
  
  // 님의 word-grid UI에 단어 배치
  const grid = document.getElementById('q2-word-grid');
  // 단어 개수에 따라 그리드 컬럼 자동 조정 (님의 CSS 클래스 활용)
  const totalCount = finalWords.length;
  grid.className = `word-grid cols-${totalCount > 4 ? 5 : totalCount}`;
  
  grid.innerHTML = finalWords.map((word, i) => `
    <div class="word-card-wrap">
      <div class="word-num">①</div>
      <div class="word-card">
        <div class="word-korean">${word.k}</div>
      </div>
    </div>
  `).join('');

  // 화면 전환 (설정 -> 테스트 화면)
  showScreen('test-screen');
}

// 2. 배열을 무작위로 섞는 유틸리티 (반별 랜덤의 핵심)
function shuffleArray(array) {
  const newArr = [...array];
  for (let i = newArr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [newArr[i], newArr[j]] = [newArr[j], newArr[i]];
  }
  return newArr;
}

// 3. 화면 전환 함수 (님의 screen.active 로직 준수)
function showScreen(screenId) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const target = document.getElementById(screenId);
  if (target) {
    target.classList.add('active');
    target.style.display = 'flex'; // 님의 CSS flex 로직 적용
  }
}

