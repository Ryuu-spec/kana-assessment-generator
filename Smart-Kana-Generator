<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>가나비 — 히라가나·가타카나 수행평가</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700;900&family=Noto+Sans+JP:wght@400;700&display=swap');

  :root {
    --bg: #f5f2e8;
    --card: #ffffff;
    --green-light: #c8ddb0;
    --green-dark: #5a8a3c;
    --green-btn: #c8ddb0;
    --green-text: #4a7a32;
    --text: #2d2d2d;
    --text-light: #666;
    --border: #d0c9b0;
    --shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Noto Sans KR', sans-serif;
    background: var(--bg);
    min-height: 100vh;
    color: var(--text);
  }

  /* 화면 활성화 로직 보강 */
  .screen {
    display: none; /* 기본적으로 숨김 */
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 40px 20px;
  }
  
  /* active 클래스가 붙으면 flex로 노출 */
  .screen.active { 
    display: flex !important; 
  }

  .logo-area { margin-bottom: 28px; text-align: center; }
  .logo-tagline {
    font-size: clamp(1.4rem, 3.5vw, 1.9rem);
    font-weight: 900;
    color: var(--green-dark);
    letter-spacing: -0.5px;
  }

  .settings-card {
    background: var(--card);
    border-radius: 20px;
    padding: clamp(24px, 5vw, 40px);
    box-shadow: var(--shadow);
    width: 100%;
    max-width: 580px;
  }

  .section-title {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-light);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid #eee;
  }

  .row-btn-group { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 4px; }
  .row-btn {
    padding: 9px 18px; border-radius: 20px;
    border: 2px solid #d8d8d8; background: white;
    cursor: pointer; transition: all 0.15s; font-weight: 700;
  }
  .row-btn.selected { border-color: var(--green-btn); background: var(--green-btn); color: var(--green-text); }

  .stepper-group { display: flex; gap: 10px; flex-wrap: wrap; }
  .stepper-item {
    flex: 1; min-width: 100px; background: #f8f7f2;
    border-radius: 12px; padding: 12px 10px; border: 1px solid var(--border); text-align: center;
  }
  .stepper-btn {
    width: 28px; height: 28px; border-radius: 8px;
    border: 2px solid var(--green-light); background: white;
    cursor: pointer; font-weight: 900;
  }

  .btn-primary {
    background: var(--green-btn); color: var(--green-text); border: none;
    border-radius: 10px; padding: 13px 32px; font-size: 1rem; font-weight: 700;
    width: 100%; cursor: pointer; margin-top: 10px;
  }
  .btn-primary:disabled { background: #bbb; cursor: not-allowed; }

  .select-card {
    background: var(--card); border-radius: 20px; padding: 48px;
    width: 100%; max-width: 500px; text-align: center; box-shadow: var(--shadow);
  }
  .select-btn-group { display: flex; gap: 16px; margin-top: 20px; }
  .select-btn {
    flex: 1; padding: 28px 16px; border-radius: 16px; border: 2px solid var(--border);
    background: white; cursor: pointer; transition: all 0.15s;
  }
  .select-btn:hover { background: #f4f9ef; border-color: var(--green-btn); }
  .select-kana { font-size: 2.2rem; font-weight: 700; color: var(--green-text); display: block; }

  #test-screen { display: none; padding: 2vh 8vw; width: 100%; flex-direction: column; }
</style>
</head>
<body>

<div id="select-screen" class="screen active">
  <div class="logo-area">
    <span class="logo-tagline">가나 수행평가 생성기</span>
    <p style="margin-top:10px; color:#666;">2022 개정 교육과정 기준 적용</p>
  </div>
  <div class="select-card">
    <h2>평가할 문자를 선택하세요</h2>
    <div class="select-btn-group">
      <button class="select-btn" onclick="selectScript('hiragana')">
        <span class="select-kana">あ</span>
        <span class="select-label">히라가나</span>
      </button>
      <button class="select-btn" onclick="selectScript('katakana')">
        <span class="select-kana">ア</span>
        <span class="select-label">가타카나</span>
      </button>
    </div>
  </div>
</div>

<div id="settings-screen" class="screen">
  <div class="settings-card">
    <div class="section-title">1번 문제 — 출제 행 선택</div>
    <div class="row-btn-group" id="q1-row-btns"></div>
    <div style="margin: 20px 0; border-top: 1px solid #eee;"></div>
    <div class="section-title">2번 문제 — 난이도별 단어 수 (AI 자동분류)</div>
    <div class="stepper-group">
      <div class="stepper-item"><div>상</div><button onclick="changeCount('sang',-1)">-</button><span id="val-sang">1</span><button onclick="changeCount('sang',1)">+</button></div>
      <div class="stepper-item"><div>중</div><button onclick="changeCount('jung',-1)">-</button><span id="val-jung">2</span><button onclick="changeCount('jung',1)">+</button></div>
      <div class="stepper-item"><div>하</div><button onclick="changeCount('ha',-1)">-</button><span id="val-ha">1</span><button onclick="changeCount('ha',1)">+</button></div>
    </div>
    <button class="btn-primary" onclick="showScreen('upload-screen')">다음 → 파일 업로드</button>
  </div>
</div>

<div id="upload-screen" class="screen">
  <div class="settings-card" style="text-align:center;">
    <h2>엑셀 파일 업로드</h2>
    <div style="border:2px dashed #c8ddb0; padding:40px; margin:20px 0; cursor:pointer;" onclick="document.getElementById('file-input').click()">
      파일을 선택하거나 끌어다 놓으세요
    </div>
    <input type="file" id="file-input" accept=".xlsx,.xls" style="display:none;" onchange="handleFile(this)">
    <div id="file-status" style="margin-bottom:15px; color:var(--green-dark);"></div>
    <button class="btn-primary" id="generate-btn" disabled onclick="generateTest()">문제 생성하기</button>
  </div>
</div>

<div id="test-screen" class="screen">
  <h1 id="test-title">수행평가</h1>
  <div id="q1-area" style="margin:20px 0; padding:20px; background:white; width:100%; border-radius:15px;"></div>
  <div id="q2-grid" class="word-grid" style="display:grid; grid-template-columns:repeat(2, 1fr); gap:10px; width:100%;"></div>
  <button class="btn-primary" style="width:200px; margin-top:30px;" onclick="window.print()">인쇄하기</button>
</div>

<script>
let currentScript = 'hiragana';
let selectedFrontRows = [];
let wordData = { sang: [], jung: [], ha: [] };
const counts = { sang: 1, jung: 2, ha: 1 };
const ALL_ROWS = ['아행','카행','사행','타행','나행','하행','마행','라행','야행+와행'];

// [수정] 화면 전환 함수 - display 속성을 직접 제어하여 충돌 방지
function showScreen(screenId) {
  const screens = document.querySelectorAll('.screen');
  screens.forEach(s => {
    s.classList.remove('active');
    s.style.display = 'none';
  });

  const target = document.getElementById(screenId);
  if (target) {
    target.classList.add('active');
    target.style.display = 'flex';
  }
}

// [수정] 첫 페이지 클릭 시 실행되는 함수
function selectScript(type) {
  currentScript = type;
  
  // 행 버튼 생성
  const btnGroup = document.getElementById('q1-row-btns');
  btnGroup.innerHTML = ALL_ROWS.map(r => 
    `<button class="row-btn" onclick="toggleRow(this, '${r}')">${r}</button>`
  ).join('');
  
  showScreen('settings-screen');
}

function toggleRow(btn, row) {
  btn.classList.toggle('selected');
  if (btn.classList.contains('selected')) selectedFrontRows.push(row);
  else selectedFrontRows = selectedFrontRows.filter(r => r !== row);
}

function changeCount(key, delta) {
  counts[key] = Math.max(0, Math.min(10, counts[key] + delta));
  document.getElementById('val-' + key).textContent = counts[key];
}

// AI 난이도 분석 (2022 개정 교육과정 기준)
function analyzeDifficulty(word) {
  let score = word.length <= 2 ? 1 : (word.length <= 4 ? 2 : 3);
  if (/[ゃゅょャュョっッ]/.test(word)) score += 2;
  if (/[ーが-ぼぱ-포]/.test(word)) score += 1;
  
  const easy = ["さくら", "すし", "いぬ", "アメリカ", "カメラ"];
  if (easy.includes(word)) return "ha";
  
  return score <= 2 ? "ha" : (score <= 4 ? "jung" : "sang");
}

function handleFile(input) {
  const file = input.files[0];
  const reader = new FileReader();
  reader.onload = function(e) {
    const data = new Uint8Array(e.target.result);
    const workbook = XLSX.read(data, {type: 'array'});
    const rows = XLSX.utils.sheet_to_json(workbook.Sheets[workbook.SheetNames[0]], {header: 1});
    
    wordData = { sang: [], jung: [], ha: [] };
    rows.forEach(row => {
      if (row[0] && row[1]) {
        const level = analyzeDifficulty(row[0].toString());
        wordData[level].push({ word: row[0], mean: row[1] });
      }
    });
    document.getElementById('file-status').textContent = `분류 완료! (상:${wordData.sang.length} 중:${wordData.jung.length} 하:${wordData.ha.length})`;
    document.getElementById('generate-btn').disabled = false;
  };
  reader.readAsArrayBuffer(file);
}

function generateTest() {
  const q1Row = selectedFrontRows[Math.floor(Math.random() * selectedFrontRows.length)] || "아행";
  document.getElementById('q1-area').innerHTML = `<h3>1. 다음 행의 글자를 쓰시오: <span style="color:var(--green-dark)">${q1Row}</span></h3>`;
  
  const grid = document.getElementById('q2-grid');
  grid.innerHTML = '';
  const selected = [
    ...wordData.sang.sort(() => .5 - Math.random()).slice(0, counts.sang),
    ...wordData.jung.sort(() => .5 - Math.random()).slice(0, counts.jung),
    ...wordData.ha.sort(() => .5 - Math.random()).slice(0, counts.ha)
  ];
  
  selected.forEach((w, i) => {
    grid.innerHTML += `<div style="border:1px solid #ccc; padding:10px; background:white;">${i+1}. ${w.mean} ( )</div>`;
  });
  
  showScreen('test-screen');
}

// 초기 화면 설정
window.onload = () => showScreen('select-screen');
</script>
</body>
</html>
