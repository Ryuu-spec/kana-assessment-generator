<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>가나비 — 히라가나·가타카나 수행평가</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700;900&family=Noto+Sans+JP:wght@400;700&display=swap');

  :root {
    --bg: #f5f2e8;
    --card: #ffffff;
    --green-light: #c8ddb0;
    --green-dark: #5a8a3c;
    --green-btn: #c8ddb0;
    --green-text: #4a7a32;
    --text: #2d2d2d;
    --text-light: #666;
    --border: #d0c9b0;
    --shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Noto Sans KR', sans-serif;
    background: var(--bg);
    min-height: 100vh;
    color: var(--text);
  }

  /* 화면 활성화 버그 수정을 위해 !important 추가 */
  .screen {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 40px 20px;
  }
  .screen.active { display: flex !important; }

  .logo-area { margin-bottom: 28px; text-align: center; }
  .logo-mark {
    display: inline-flex; align-items: center; justify-content: center;
    margin-bottom: 6px;
  }
  .logo-tagline {
    font-size: clamp(1.4rem, 3.5vw, 1.9rem);
    font-weight: 900;
    color: var(--green-dark);
    letter-spacing: -0.5px;
  }
  .logo-area p { color: var(--text-light); font-size: 0.9rem; margin-top: 4px; }

  /* ── 설정 카드 ── */
  .settings-card {
    background: var(--card);
    border-radius: 20px;
    padding: clamp(24px, 5vw, 40px) clamp(20px, 6vw, 48px);
    box-shadow: var(--shadow);
    width: 100%;
    max-width: 580px;
  }

  .section-title {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-light);
    letter-spacing: 1.2px;
    text-transform: uppercase;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid #eee;
  }
  .section-label {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
  }

  /* 행 선택 버튼 */
  .row-btn-group { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 4px; }
  .row-btn {
    padding: 9px 18px; border-radius: 20px;
    border: 2px solid #d8d8d8;
    background: white; color: var(--text-light);
    font-size: 0.88rem; font-weight: 700;
    font-family: 'Noto Sans KR', sans-serif;
    cursor: pointer; transition: all 0.15s; user-select: none;
  }
  .row-btn:hover { border-color: var(--green-btn); background: #f4f9ef; color: var(--green-text); }
  .row-btn.selected { border-color: var(--green-btn); background: var(--green-btn); color: var(--green-text); }

  /* 스테퍼 */
  .stepper-group { display: flex; gap: 10px; flex-wrap: wrap; }
  .stepper-item {
    flex: 1; min-width: 100px;
    background: #f8f7f2;
    border-radius: 12px;
    padding: 12px 10px;
    border: 1px solid var(--border);
    text-align: center;
  }
  .stepper-label {
    font-size: 0.8rem; font-weight: 700;
    margin-bottom: 8px;
    display: flex; align-items: center; justify-content: center; gap: 5px;
  }
  .diff-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
  .diff-dot.sang { background: #e74c3c; }
  .diff-dot.jung { background: #f39c12; }
  .diff-dot.ha   { background: #27ae60; }

  .stepper-controls { display: flex; align-items: center; justify-content: center; gap: 8px; }
  .stepper-btn {
    width: 28px; height: 28px; border-radius: 8px;
    border: 2px solid var(--green-light); background: white;
    color: var(--green-dark); font-size: 1.1rem; font-weight: 900;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all 0.1s; line-height: 1;
  }
  .stepper-btn:hover { background: var(--green-light); }
  .stepper-val { font-size: 1.3rem; font-weight: 900; color: var(--text); min-width: 22px; }

  .total-badge { text-align: center; margin-top: 10px; font-size: 0.82rem; color: var(--text-light); }
  .total-badge span { font-weight: 700; color: var(--green-dark); }

  .divider { border: none; border-top: 1px solid #eee; margin: 22px 0; }

  .btn-primary {
    background: var(--green-btn); color: var(--green-text); border: none;
    border-radius: 10px; padding: 13px 32px;
    font-size: 1rem; font-weight: 700; width: 100%; cursor: pointer;
  }
  .btn-primary:disabled { background: #bbb; cursor: not-allowed; }

  .btn-secondary {
    background: white; color: var(--green-text);
    border: 2px solid var(--green-btn); border-radius: 10px;
    padding: 11px 32px; width: 100%; margin-top: 10px; cursor: pointer;
    font-weight: 700;
  }

  /* ── 업로드 카드 ── */
  .upload-card {
    background: var(--card); border-radius: 20px;
    padding: 40px; box-shadow: var(--shadow); width: 100%; max-width: 520px; text-align: center;
  }
  .drop-zone {
    border: 2px dashed var(--green-light); border-radius: 14px;
    padding: 36px 20px; cursor: pointer; transition: all 0.2s;
    margin-bottom: 16px; background: #f9fdf5;
  }
  .drop-zone:hover { background: #eef8e4; border-color: var(--green-dark); }

  /* ── 테스트 화면 ── */
  #test-screen {
    display: none; padding: 2vh 8vw; width: 100%; height: 100vh;
    flex-direction: column; max-width: 1100px; margin: 0 auto;
  }
  .question-block {
    background: var(--card); border-radius: 16px; padding: 2vh 3vw;
    margin-bottom: 1.2vh; box-shadow: var(--shadow); flex: 1;
  }
  .word-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1.2vw; margin-top: 1vh; }

  /* ── 문자 선택 카드 ── */
  .select-card {
    background: var(--card); border-radius: 20px; padding: 48px;
    width: 100%; max-width: 500px; text-align: center; box-shadow: var(--shadow);
  }
  .select-btn-group { display: flex; gap: 16px; margin-top: 30px; }
  .select-btn {
    flex: 1; padding: 28px 16px; border-radius: 16px; border: 2px solid var(--border);
    background: white; cursor: pointer; transition: all 0.15s;
  }
  .select-btn .select-kana { font-size: 2.2rem; font-weight: 700; color: var(--green-text); display: block; }

  .btn-click-here {
    background: var(--green-btn); color: var(--green-text); border: none;
    border-radius: 10px; padding: 1.2vh 6vw; font-size: 1.1rem; font-weight: 700;
    position: fixed; bottom: 2.5vh; left: 50%; transform: translateX(-50%); cursor: pointer;
  }
</style>
</head>
<body>

<div id="select-screen" class="screen active">
  <div class="logo-area">
    <div class="logo-mark">
      <span class="logo-tagline">가나 수행평가 생성기</span>
    </div>
    <p>2022 개정 교육과정 기준 적용</p>
  </div>
  <div class="select-card">
    <h2>평가할 문자를 선택하세요</h2>
    <div class="select-btn-group">
      <button class="select-btn" onclick="selectScript('hiragana')">
        <span class="select-kana">あ</span>
        <span class="select-label">히라가나</span>
      </button>
      <button class="select-btn" onclick="selectScript('katakana')">
        <span class="select-kana">ア</span>
        <span class="select-label">가타카나</span>
      </button>
    </div>
  </div>
</div>

<div id="settings-screen" class="screen">
  <div class="logo-area">
    <div class="logo-mark"><span class="logo-tagline" id="settings-logo-tagline">수행평가 설정</span></div>
  </div>
  <div class="settings-card">
    <div class="section-title">1번 문제 — 출제 행 선택</div>
    <div class="row-btn-group" id="q1-row-btns"></div>
    
    <hr class="divider">
    
    <div class="section-title">2번 문제 — 난이도별 단어 수 (AI 자동분류)</div>
    <div class="stepper-group">
      <div class="stepper-item">
        <div class="stepper-label"><span class="diff-dot sang"></span> 상</div>
        <div class="stepper-controls">
          <button class="stepper-btn" onclick="changeCount('sang',-1)">−</button>
          <div class="stepper-val" id="val-sang">1</div>
          <button class="stepper-btn" onclick="changeCount('sang',1)">+</button>
        </div>
      </div>
      <div class="stepper-item">
        <div class="stepper-label"><span class="diff-dot jung"></span> 중</div>
        <div class="stepper-controls">
          <button class="stepper-btn" onclick="changeCount('jung',-1)">−</button>
          <div class="stepper-val" id="val-jung">2</div>
          <button class="stepper-btn" onclick="changeCount('jung',1)">+</button>
        </div>
      </div>
      <div class="stepper-item">
        <div class="stepper-label"><span class="diff-dot ha"></span> 하</div>
        <div class="stepper-controls">
          <button class="stepper-btn" onclick="changeCount('ha',-1)">−</button>
          <div class="stepper-val" id="val-ha">1</div>
          <button class="stepper-btn" onclick="changeCount('ha',1)">+</button>
        </div>
      </div>
    </div>
    <div class="total-badge" id="total-badge">총 단어 수: <span>4</span>개</div>
    <button class="btn-primary" style="margin-top:20px;" onclick="showScreen('upload-screen')">다음 → 파일 업로드</button>
  </div>
</div>

<div id="upload-screen" class="screen">
  <div class="upload-card">
    <h2>📋 엑셀 파일 업로드</h2>
    <p style="font-size:0.85rem; color:#666; margin-bottom:20px;">AI가 교육과정에 맞춰 단어를 자동 분류합니다.</p>
    <div class="drop-zone" onclick="document.getElementById('file-input').click()">
      <div class="icon">📂</div>
      <p>엑셀 파일을 여기에 끌어다 놓으세요</p>
    </div>
    <input type="file" id="file-input" accept=".xlsx,.xls" style="display:none;" onchange="handleFile(this)">
    <div id="file-status" style="margin:15px 0; font-size:0.9rem; color:var(--green-dark);"></div>
    <button class="btn-primary" id="generate-btn" disabled onclick="generateTest()">문제 생성하기</button>
    <button class="btn-secondary" onclick="showScreen('settings-screen')">← 이전으로</button>
  </div>
</div>

<div id="test-screen">
  <div class="test-header" style="text-align:center; margin-bottom:20px;">
    <h1 id="test-title" style="font-size:2.5rem;">히라가나 쓰기</h1>
  </div>
  <div class="question-block">
    <div class="q-instruction" id="q1-instruction" style="font-size:1.3rem; font-weight:700;">1. 해당 행의 글자를 쓰시오.</div>
    <div id="q1-display" style="font-size:2rem; margin-top:10px; color:var(--green-dark); font-weight:900;"></div>
  </div>
  <div class="question-block">
    <div class="q-instruction" style="font-size:1.3rem; font-weight:700;">2. 다음 단어를 일본어로 쓰시오.</div>
    <div class="word-grid" id="q2-word-grid"></div>
  </div>
  <button class="btn-click-here" onclick="window.print()">인쇄하기</button>
</div>

<script>
let currentScript = 'hiragana';
let selectedFrontRows = [];
let wordData = { sang: [], jung: [], ha: [] };
const counts = { sang: 1, jung: 2, ha: 1 };

const ALL_ROWS = ['아행','카행','사행','타행','나행','하행','마행','라행','야행+와행'];

// ── 화면 전환 함수 ──
function showScreen(screenId) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('test-screen').style.display = 'none';
  
  const target = document.getElementById(screenId);
  if (target) target.classList.add('active');
  else if (screenId === 'test-screen') target.style.display = 'flex';
}

// ── 문자 선택 ──
function selectScript(type) {
  currentScript = type;
  document.getElementById('settings-logo-tagline').textContent = (type === 'hiragana' ? '히라가나' : '가타카나') + ' 수행평가';
  
  const btnGroup = document.getElementById('q1-row-btns');
  btnGroup.innerHTML = ALL_ROWS.map(r => 
    `<button class="row-btn" onclick="toggleRow(this, '${r}')">${r}</button>`
  ).join('');
  
  showScreen('settings-screen');
}

function toggleRow(btn, row) {
  btn.classList.toggle('selected');
  if (btn.classList.contains('selected')) selectedFrontRows.push(row);
  else selectedFrontRows = selectedFrontRows.filter(r => r !== row);
}

function changeCount(key, delta) {
  counts[key] = Math.max(0, Math.min(10, counts[key] + delta));
  document.getElementById('val-' + key).textContent = counts[key];
  document.getElementById('total-badge').querySelector('span').textContent = counts.sang + counts.jung + counts.ha;
}

// ── 2022 교육과정 기반 AI 난이도 분석 로직 ──
function analyzeDifficulty(word) {
  const length = word.length;
  let score = 0;

  if (length <= 2) score += 1;
  else if (length <= 4) score += 2;
  else score += 3;

  // 특수 음운 체크
  const hasSpecial = /[ゃゅょャュョっッ]/.test(word); // 요음, 촉음
  const hasRules = /[가-힣]/.test(word) || /[ーが-ぼぱ-ぽガ-ボ파-ポ]/.test(word); // 탁음, 장음

  if (hasSpecial) score += 2;
  if (hasRules) score += 1;

  // 한국인 친숙도 보정 (벚꽃, 초밥 등)
  const easyWords = ["さくら", "すし", "いぬ", "アメリカ", "カメラ"];
  if (easyWords.includes(word)) return "ha";

  if (score <= 2) return "ha";
  if (score <= 4) return "jung";
  return "sang";
}

// ── 파일 처리 ──
function handleFile(input) {
  const file = input.files[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = function(e) {
    const data = new Uint8Array(e.target.result);
    const workbook = XLSX.read(data, {type: 'array'});
    const sheet = workbook.Sheets[workbook.SheetNames[0]];
    const rows = XLSX.utils.sheet_to_json(sheet, {header: 1});

    wordData = { sang: [], jung: [], ha: [] };
    
    rows.forEach(row => {
      const word = row[0]; // A열: 단어
      const mean = row[1]; // B열: 뜻
      if (word && mean) {
        const level = analyzeDifficulty(word.toString());
        wordData[level].push({ kanji: word, mean: mean });
      }
    });

    document.getElementById('file-status').textContent = `분류 완료: 상(${wordData.sang.length}) 중(${wordData.jung.length}) 하(${wordData.ha.length})`;
    document.getElementById('generate-btn').disabled = false;
  };
  reader.readAsArrayBuffer(file);
}

// ── 문제 생성 ──
function generateTest() {
  const q1Row = selectedFrontRows[Math.floor(Math.random() * selectedFrontRows.length)] || "아행";
  document.getElementById('q1-display').textContent = q1Row;

  const q2Grid = document.getElementById('q2-word-grid');
  q2Grid.innerHTML = '';

  const selectedWords = [
    ...getRandom(wordData.sang, counts.sang),
    ...getRandom(wordData.jung, counts.jung),
    ...getRandom(wordData.ha, counts.ha)
  ];

  selectedWords.forEach((w, i) => {
    q2Grid.innerHTML += `
      <div style="border:2px solid var(--green-light); padding:15px; border-radius:10px; text-align:center;">
        <div style="font-size:0.8rem; color:var(--green-dark);">${i+1}번</div>
        <div style="font-size:1.4rem; font-weight:700;">${w.mean}</div>
        <div style="height:40px; border-bottom:1px dashed #ccc; margin-top:10px;"></div>
      </div>
    `;
  });

  showScreen('test-screen');
  document.getElementById('test-screen').style.display = 'flex';
}

function getRandom(arr, n) {
  const shuffled = [...arr].sort(() => 0.5 - Math.random());
  return shuffled.slice(0, n);
}
</script>

</body>
</html>
