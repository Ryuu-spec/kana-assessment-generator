<script>

// ── [추가] 난이도 데이터베이스 ──
const INTERNAL_DB = {
  hiragana: {
    sang: ['きゅうり', 'しゅくだい', 'きょうしつ', 'じゅうどう', 'ちょうちょ', 'しょうゆ', 'りゅうがく', 'ちゅうしゃじょう', 'びょうき', 'きょねん', 'いっしょ', 'ちょっと', 'きっぷ', 'ざっし', 'がっこう'],
    jung: ['せんせい', 'かばん', 'じてんしゃ', 'でんわ', 'とけい', 'くだもの', 'べんきょう', 'なまえ', 'あした', 'きのう', 'こうえん', 'えんぴつ', 'めがね', 'けしごむ', 'ぼうし'],
    ha: ['いぬ', 'ね코', 'かさ', 'とり', 'はな', 'やま', 'すし', 'さくら', 'あめ', 'うみ', 'つき', 'そら', 'ゆき', 'とり', 'ひと']
  },
  katakana: {
    sang: ['チョコレート', 'コンピューター', 'スマートフォン', 'アイスクリーム', 'タクシー', 'プレゼント', 'レストラン', 'デパート', 'ニュース', 'ジュース'],
    jung: ['カメラ', 'テレビ', 'ノート', 'ペン', 'トイレ', 'バス', 'ビル', 'ドア', 'コップ', 'パン'],
    ha: ['アメリカ', 'フランス', 'ドイツ', 'イタリア', 'アジア', 'ピアノ', 'ギター', 'ラジオ', 'シャツ', 'クラス']
  }
};

// ── 문자 종류 ──
let currentScript = 'hiragana'; // 'hiragana' or 'katakana'

const ROWS_MAP = {
  hiragana: ['아행','카행','사행','타행','나행','하행','마행','라행','야행+와행'],
  katakana: ['아행','카행','사행','타행','나행','하행','마행','라행','야행+와행']
};

function selectScript(type) {
  currentScript = type;
  // 행 버튼 업데이트
  const rows = ROWS_MAP[type];
  const btnGroup = document.getElementById('q1-row-btns');
  btnGroup.innerHTML = rows.map(r =>
    `<button class="row-btn" onclick="selectFrontRow(this,'${r}')">${r}</button>`
  ).join('');
  selectedFrontRows = [];
  updateSecondRowPreview();

  // 제목 업데이트
  const titleText = type === 'hiragana' ? '히라가나 쓰기' : '가타카나 쓰기';
  const scriptLabel = type === 'hiragana' ? '히라가나' : '가타카나';
  document.querySelector('.test-header h1') && (document.querySelector('.test-header h1').textContent = titleText);
  document.getElementById('test-title') && (document.getElementById('test-title').textContent = titleText);
  // 화면별 타이틀 업데이트
  ['settings-logo-tagline','upload-logo-tagline'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.textContent = type === 'hiragana' ? '히라가나 수행평가' : '가타카나 수행평가';
  });
  // q1 지시문 앞부분 업데이트 (badges span은 유지)
  const q1inst = document.getElementById('q1-instruction');
  // textContent를 직접 설정하면 내부 span이 사라지므로, textNode를 변경
  if (q1inst && q1inst.childNodes.length > 0) {
      q1inst.childNodes[0].nodeValue = scriptLabel + ' ';
  }
  document.getElementById('q2-instruction').textContent = `다음 단어에 해당하는 일본어를 ${scriptLabel}로 쓰시오.`;
  // (브랜드 이름은 항상 가나비로 고정)

  showScreen('settings-screen');
}

// ── 로그인 관련 코드 삭제 ──
// const GAS_URL = '...'; (삭제)
// document.getElementById('loginEmail').addEventListener('keydown', ...); (삭제)
// async function handleLogin() { ... } (삭제)
// function showLoginResult(msg) { ... } (삭제)

// 전체 행 목록
const ALL_ROWS = ['아행','카행','사행','타행','나행','하행','마행','라행','야행+와행'];

// 첫 번째 행으로 선택된 행들
let selectedFrontRows = [];  // 기본 미선택

function selectFrontRow(btn, rowName) {
  const isSelected = btn.classList.contains('selected');

  if (isSelected) {
    // 마지막 1개는 해제 불가
    if (selectedFrontRows.length === 1) {
      document.getElementById('q1-warning').style.display = 'block';
      setTimeout(() => document.getElementById('q1-warning').style.display = 'none', 2000);
      return;
    }
    btn.classList.remove('selected');
    selectedFrontRows = selectedFrontRows.filter(r => r !== rowName);
  } else {
    btn.classList.add('selected');
    selectedFrontRows.push(rowName);
  }
  updateSecondRowPreview();
}

function updateSecondRowPreview() {
  const currentRows = ROWS_MAP[currentScript] || ALL_ROWS;
  const secondPool = currentRows.filter(r => !selectedFrontRows.includes(r));
  const el = document.getElementById('second-row-preview');
  if (secondPool.length === 0) {
    el.textContent = '(없음 - 모든 행이 첫 번째로 선택됨)';
  } else {
    el.textContent = secondPool.join(' · ') + ' 중 자동 랜덤';
  }
}
const counts = { sang: 1, jung: 2, ha: 1 };
let wordData = { sang: [], jung: [], ha: [] }; // 업로드된 데이터를 저장하는 변수

// ── 스테퍼 ──
function changeCount(key, delta) {
  const total = counts.sang + counts.jung + counts.ha;
  // 총합이 1인 상태에서 마이너스 시도 시 차단
  if (delta < 0 && total <= 1) return;
  counts[key] = Math.max(0, Math.min(6, counts[key] + delta));
  document.getElementById('val-' + key).textContent = counts[key];
  const newTotal = counts.sang + counts.jung + counts.ha;
  document.getElementById('total-badge').innerHTML = `총 단어 수: <span>${newTotal}</span>개`;
  // 총합이 1이면 모든 − 버튼 비활성화
  document.querySelectorAll('.stepper-btn').forEach(btn => {
    if (btn.textContent === '−') {
      btn.disabled = newTotal <= 1;
      btn.style.opacity = newTotal <= 1 ? '0.35' : '';
      btn.style.cursor  = newTotal <= 1 ? 'not-allowed' : '';
    }
  });
}

// ── localStorage 저장 단어 관리 ──
function initSavedBanner() {
  try {
    const saved = localStorage.getItem('gana_wordData');
    const savedName = localStorage.getItem('gana_fileName');
    if (!saved) return;
    const data = JSON.parse(saved);
    const banner = document.getElementById('saved-banner');
    banner.style.display = 'flex';
    document.getElementById('saved-file-name').textContent = savedName || '이전 파일';
    document.getElementById('saved-sang').textContent = data.sang?.length || 0;
    document.getElementById('saved-jung').textContent = data.jung?.length || 0;
    document.getElementById('saved-ha').textContent  = data.ha?.length  || 0;
  } catch(e) {}
}

function loadSavedData() {
  try {
    const saved = localStorage.getItem('gana_wordData');
    const savedName = localStorage.getItem('gana_fileName');
    if (!saved) return;
    wordData = JSON.parse(saved);
    const ok = wordData.sang.length >= counts.sang
            && wordData.jung.length >= counts.jung
            && wordData.ha.length  >= counts.ha;
    const status = document.getElementById('file-status');
    const replaceRow = document.getElementById('file-replace-row');
    if (!ok) {
      status.style.color = '#e74c3c';
      status.textContent = `⚠️ 저장 데이터: 상 ${wordData.sang.length}개, 중 ${wordData.jung.length}개, 하 ${wordData.ha.length}개 (설정: 상 ${counts.sang}/중 ${counts.jung}/하 ${counts.ha}개 필요)`;
      document.getElementById('generate-btn').disabled = true;
    } else {
      status.style.color = 'var(--green-dark)';
      status.textContent = `✅ ${savedName || '저장된 파일'} — 상 ${wordData.sang.length}개, 중 ${wordData.jung.length}개, 하 ${wordData.ha.length}개`;
      document.getElementById('generate-btn').disabled = false;
      const dz = document.getElementById('drop-zone');
      dz.style.padding = '14px 20px';
      dz.querySelector('.icon').style.display = 'none';
      dz.querySelector('p').textContent = '저장된 파일을 불러왔습니다';
      replaceRow.style.display = 'block';
    }
    document.getElementById('saved-banner').style.display = 'none';
  } catch(e) {}
}

function clearSavedData() {
  localStorage.removeItem('gana_wordData');
  localStorage.removeItem('gana_fileName');
  document.getElementById('saved-banner').style.display = 'none';
  // 데이터 삭제 후 wordData를 초기화하고, generate-btn을 다시 활성화 (내부 DB 사용 가능하도록)
  wordData = { sang: [], jung: [], ha: [] };
  document.getElementById('generate-btn').disabled = false;
  // 드롭존도 초기 상태로 복구
  const dz = document.getElementById('drop-zone');
  dz.style.padding = '';
  const icon = dz.querySelector('.icon');
  if (icon) icon.style.display = '';
  const ps = dz.querySelectorAll('p');
  if (ps[0]) ps[0].innerHTML = '<strong>클릭</strong>하거나 파일을 여기에 끌어다 놓으세요';
  document.getElementById('file-replace-row').style.display = 'none';
  document.getElementById('file-status').textContent = '';
  document.getElementById('file-input').value = ''; // 파일 인풋도 초기화
}

// ── 화면 전환 ──
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('test-screen').style.display = 'none';
  document.getElementById(id).classList.add('active');
}
function goToUpload() {
  if (selectedFrontRows.length === 0) {
    alert('첫 번째 행을 1개 이상 선택해주세요.'); return;
  }
  if (counts.sang + counts.jung + counts.ha === 0) {
    alert('단어 수를 1개 이상 설정해주세요.'); return;
  }
  showScreen('upload-screen');
  initSavedBanner();
}
function goToSettings() {
  // 드롭존 초기화
  const dz = document.getElementById('drop-zone');
  dz.style.padding = '';
  const icon = dz.querySelector('.icon');
  if (icon) icon.style.display = '';
  const ps = dz.querySelectorAll('p');
  if (ps[0]) ps[0].innerHTML = '<strong>클릭</strong>하거나 파일을 여기에 끌어다 놓으세요';
  document.getElementById('file-replace-row').style.display = 'none';
  document.getElementById('file-status').textContent = '';
  // generate-btn은 파일 업로드 여부와 관계없이 활성화될 수 있도록 disabled 초기화 (내부 DB 사용)
  document.getElementById('generate-btn').disabled = false;
  document.getElementById('file-input').value = '';
  wordData = { sang: [], jung: [], ha: [] }; // settings로 돌아가면 업로드 데이터 초기화
  showScreen('settings-screen');
}

// ── 파일 업로드 ──
const dropZone = document.getElementById('drop-zone');
const fileInput = document.getElementById('file-input');
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
dropZone.addEventListener('drop', e => {
  e.preventDefault(); dropZone.classList.remove('dragover');
  if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
});
fileInput.addEventListener('change', e => { if (e.target.files[0]) handleFile(e.target.files[0]); });

function handleFile(file) {
  const reader = new FileReader();
  reader.onload = function(ev) {
    const wb = XLSX.read(ev.target.result, { type: 'binary' });
    const ws = wb.Sheets[wb.SheetNames[0]];
    const rows = XLSX.utils.sheet_to_json(ws, { header: 1 });
    wordData = { sang: [], jung: [], ha: [] };
    rows.forEach(row => {
      if (row[0]) wordData.sang.push(String(row[0]).trim());
      if (row[1]) wordData.jung.push(String(row[1]).trim());
      if (row[2]) wordData.ha.push(String(row[2]).trim());
    });
    // 엑셀 헤더(예: '상', '중', '하')가 데이터로 들어가는 것을 방지
    ['sang','jung','ha'].forEach(k => {
      // 첫 번째 요소가 난이도명(한글 또는 영문 대소문자)과 일치하면 제거
      if (wordData[k].length && ['상','중','하','A','B','C','a','b','c'].includes(wordData[k][0]))
        wordData[k].shift();
    });

    const status = document.getElementById('file-status');
    const replaceRow = document.getElementById('file-replace-row');
    const ok = wordData.sang.length >= counts.sang
            && wordData.jung.length >= counts.jung
            && wordData.ha.length  >= counts.ha;
    if (!ok) {
      status.style.color = '#e74c3c';
      status.textContent = `⚠️ 업로드: 상 ${wordData.sang.length}개, 중 ${wordData.jung.length}개, 하 ${wordData.ha.length}개 (설정: 상 ${counts.sang}/중 ${counts.jung}/하 ${counts.ha}개 필요)`;
      document.getElementById('generate-btn').disabled = true;
      replaceRow.style.display = 'block';
    } else {
      status.style.color = 'var(--green-dark)';
      status.textContent = `✅ ${file.name} — 상 ${wordData.sang.length}개, 중 ${wordData.jung.length}개, 하 ${wordData.ha.length}개`;
      document.getElementById('generate-btn').disabled = false;
      // 드롭존 축소 + 파일 변경 버튼 표시
      const dz = document.getElementById('drop-zone');
      dz.style.padding = '14px 20px';
      dz.querySelector('.icon').style.display = 'none';
      dz.querySelector('p').textContent = '파일이 업로드되었습니다';
      replaceRow.style.display = 'block';
      // localStorage에 저장
      try {
        localStorage.setItem('gana_wordData', JSON.stringify(wordData));
        localStorage.setItem('gana_fileName', file.name);
        const savedBanner = document.getElementById('saved-banner');
        if (savedBanner) savedBanner.style.display = 'none';
      } catch(e) {}
    }
  };
  reader.readAsBinaryString(file);
}

// ── pick ──
function pick(arr, n) {
  const copy = [...arr], result = [];
  while (result.length < n && copy.length) {
    const i = Math.floor(Math.random() * copy.length);
    result.push(copy.splice(i, 1)[0]);
  }
  return result;
}

// ── 문제 생성 (초기 빈 화면) ──
function generateTest() {
  if (selectedFrontRows.length === 0) {
    alert('첫 번째 행을 1개 이상 선택해주세요.');
    return;
  }

  // 업로드된 데이터가 없거나, 설정된 개수를 충족하지 못하면 내부 DB 사용
  const hasEnoughUploadedData = wordData.sang.length >= counts.sang
                             && wordData.jung.length >= counts.jung
                             && wordData.ha.length  >= counts.ha;
  
  if (!hasEnoughUploadedData) {
    // 내부 DB를 사용하기 전에 wordData를 초기화 (이전 업로드 데이터가 남아있을 수 있으므로)
    wordData = JSON.parse(JSON.stringify(INTERNAL_DB[currentScript]));
    console.log("Uploaded data insufficient or empty, using internal database.");
  } else {
    console.log("Using uploaded data.");
  }

  // Q1 배지 — 빈칸으로
  document.getElementById('q1-badges-inline').innerHTML =
    `<span class="row-badge-inline blank-badge">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
     <span class="row-badge-inline blank-badge">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>`;

  // Q2 단어 카드 — 빈칸으로
  const total = counts.sang + counts.jung + counts.ha;
  const nums = ['①','②','③','④','⑤','⑥','⑦','⑧'];
  const gridEl = document.getElementById('q2-word-grid');
  gridEl.innerHTML = '';
  gridEl.className = 'word-grid';
  if (total <= 2) gridEl.classList.add('cols-2');
  else if (total === 3) gridEl.classList.add('cols-3');
  else if (total === 4) gridEl.classList.add('cols-4');

  for (let i = 0; i < total; i++) {
    const wrap = document.createElement('div');
    wrap.className = 'word-card-wrap';
    wrap.innerHTML = `
      <div class="word-num">${nums[i] || (i+1)}</div>
      <div class="word-card blank-card"><div class="word-korean"></div></div>
    `;
    gridEl.appendChild(wrap);
  }

  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('test-screen').style.display = 'flex';
  window.scrollTo(0, 0);
}

// ── Click Here → 랜덤 내용 채우기 ──
function revealTest() {
  const currentRows = ROWS_MAP[currentScript];
  const frontPool = selectedFrontRows.map(name => ({name}));
  const frontRow = pick(frontPool, 1)[0];
  const backPool = currentRows.filter(r => !selectedFrontRows.includes(r)).map(name => ({name}));
  const backRow = backPool.length > 0 ? pick(backPool, 1)[0] : {name: '—'};

  // Q1 배지 채우기
  document.getElementById('q1-badges-inline').innerHTML =
    `<span class="row-badge-inline ${frontRow.name.length > 2 ? 'long' : ''}">${frontRow.name}</span>
     <span class="row-badge-inline ${backRow.name.length > 2 ? 'long' : ''}">${backRow.name}</span>`;

  // Q2 단어 채우기
  const allWords = [
    ...pick(wordData.ha,   counts.ha),
    ...pick(wordData.jung, counts.jung),
    ...pick(wordData.sang, counts.sang),
  ];

  const nums = ['①','②','③','④','⑤','⑥','⑦','⑧'];
  const gridEl = document.getElementById('q2-word-grid');
  gridEl.innerHTML = '';
  gridEl.className = 'word-grid';
  const total = allWords.length;
  if (total <= 2) gridEl.classList.add('cols-2');
  else if (total === 3) gridEl.classList.add('cols-3');
  else if (total === 4) gridEl.classList.add('cols-4');

  allWords.forEach((word, idx) => {
    const wrap = document.createElement('div');
    wrap.className = 'word-card-wrap';
    wrap.innerHTML = `
      <div class="word-num">${nums[idx] || (idx+1)}</div>
      <div class="word-card"><div class="word-korean">${word}</div></div>
    `;
    gridEl.appendChild(wrap);
  });
}
</script>
</body>
</html>
