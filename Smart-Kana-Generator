<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>일본어 문자 쓰기 수행평가 툴</title>
<link href="https://fonts.googleapis.com/css2?family=Jeju+Gothic&family=Klee+One:wght@400;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root{
  --bg:#f7f4ed;--card:#fff;
  --green-l:#c6dca8;--green-d:#4f7e35;--green-t:#3d6428;
  --green-m:#6da048;
  --text:#2a2a2a;--text-l:#717171;--border:#ddd7c5;
  --red:#b83228;--red-bg:#fdf1ef;
  --amber:#c47d0e;--amber-bg:#fdf7e8;
  --green:#1a7d42;--green-bg:#edf9f2;
  --sh:0 2px 16px rgba(0,0,0,.07);
  --sh2:0 4px 20px rgba(0,0,0,.1);
  --r:14px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:"Jeju Gothic",sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}

.screen{display:none;}
.screen.active{display:flex;flex-direction:column;min-height:100vh;}

/* ── 헤더 ── */
.hdr{background:var(--green-d);color:#fff;padding:0 20px;height:52px;display:flex;align-items:center;gap:10px;position:sticky;top:0;z-index:200;border-bottom:1px solid rgba(0,0,0,.12);}
.hdr .brand{font-size:1.05rem;font-weight:700;letter-spacing:-0.2px;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;opacity:.95;}
.hdr .step{margin-left:auto;font-size:.66rem;font-weight:700;background:rgba(255,255,255,.18);padding:3px 10px;border-radius:20px;letter-spacing:.8px;flex-shrink:0;white-space:nowrap;}

/* ── 공통 ── */
.cwrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:28px 20px;gap:20px;}
.card{background:var(--card);border-radius:20px;border:1px solid #e8e3d5;box-shadow:var(--sh);padding:22px 26px;width:100%;transition:box-shadow .2s;}
.ctitle{font-size:.68rem;font-weight:700;color:var(--text-l);letter-spacing:1.4px;text-transform:uppercase;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.ctitle .step-badge{width:22px;height:22px;border-radius:50%;background:var(--green-l);color:var(--green-t);font-size:.72rem;font-weight:900;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;}
.ctitle::before{display:none;}

.btn{display:inline-flex;align-items:center;justify-content:center;gap:5px;padding:9px 18px;border:none;border-radius:12px;font-size:.86rem;font-weight:700;font-family:inherit;cursor:pointer;transition:all .18s;}
.btn-green{background:var(--green-l);color:var(--green-t);}
.btn-green:hover{background:#b8cf9a;transform:translateY(-1px);}
.btn-dark{background:var(--green-d);color:#fff;}
.btn-dark:hover{background:var(--green-t);transform:translateY(-2px);box-shadow:0 6px 16px rgba(79,126,53,.28);}
.btn-ol{background:#fff;color:var(--text);border:1.5px solid var(--border);}
.btn-ol:hover{border-color:var(--green-d);color:var(--green-d);}
.btn-full{width:100%;}
.btn:disabled{opacity:.35;cursor:not-allowed;transform:none !important;}

/* ══ S1: 문자 선택 ══ */
.hero{text-align:center;}
.hero h1{font-size:2rem;font-weight:900;margin-bottom:6px;color:var(--green-d);}
.hero p{color:var(--text-l);font-size:.86rem;}
.script-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;width:100%;max-width:440px;}
.script-btn{background:#fff;border:1.5px solid var(--border);border-radius:20px;padding:32px 20px;cursor:pointer;text-align:center;transition:all .25s ease;font-family:inherit;display:flex;flex-direction:column;align-items:center;}
.script-btn:hover{border-color:var(--green-d);background:#f4f9ee;transform:translateY(-4px);box-shadow:0 12px 24px rgba(0,0,0,.07);}
.script-btn .kana{font-family:"Klee One","Noto Sans JP",serif;font-size:3.2rem;color:var(--green-d);display:block;margin-bottom:10px;transition:transform .25s ease;line-height:1;}
.script-btn:hover .kana{transform:scale(1.1);}
.script-btn .lbl{font-size:.96rem;font-weight:700;display:block;}
.script-btn .sub{font-size:.72rem;color:var(--text-l);margin-top:4px;display:block;letter-spacing:.8px;}

/* ══ S2: 설정 ══ */
.row-btn-group{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:8px;}
.row-btn{padding:7px 14px;border-radius:20px;border:1.5px solid var(--border);background:#fff;color:var(--text-l);font-size:.8rem;font-weight:600;font-family:inherit;cursor:pointer;transition:all .12s;}
.row-btn:hover{border-color:var(--green-d);color:var(--green-d);}
.row-btn.on{border-color:var(--green-l);background:var(--green-l);color:var(--green-t);}
.info-box{background:#f1f8e9;border-radius:12px;padding:9px 13px;font-size:.74rem;color:var(--text-l);line-height:1.7;margin-top:6px;border:1px solid #d5e8bc;}
.info-box strong{color:var(--green-d);}

.stepper-row{display:flex;flex-direction:row;gap:8px;}
.sitem{background:var(--bg);border-radius:14px;border:1.5px solid var(--border);padding:10px 14px;flex:1;display:flex;align-items:center;justify-content:space-between;gap:8px;}
.sitem.sang{border-color:#f5c6c2;background:var(--red-bg);}
.sitem.jung{border-color:#f9e4a0;background:var(--amber-bg);}
.sitem.ha  {border-color:#a9dfbf;background:var(--green-bg);}
.slbl{font-size:.8rem;font-weight:700;margin-bottom:0;display:flex;align-items:center;gap:4px;}
.dot{width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0;}
.dot.sang{background:var(--red);}
.dot.jung{background:var(--amber);}
.dot.ha  {background:var(--green);}
.sctl{display:flex;align-items:center;justify-content:center;gap:5px;}
.sbtn{width:32px;height:32px;border-radius:9px;border:1.5px solid var(--border);background:#fff;color:var(--text);font-size:1.1rem;font-weight:900;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .12s;flex-shrink:0;}
.sbtn:hover{background:var(--green-d);color:#fff;border-color:var(--green-d);}
.sval{font-size:1.6rem;font-weight:900;min-width:28px;text-align:center;line-height:1;}
.tnote{text-align:center;font-size:.76rem;color:var(--text-l);margin-top:12px;}
.tnote b{color:var(--green-d);}
.sdivider{border:none;border-top:1px solid var(--border);margin:16px 0;}

/* ══ 행 선택기 ══ */
.dnd-zones{
  display:grid;grid-template-columns:1fr 36px 1fr;
  gap:6px;align-items:stretch;margin-bottom:16px;
}
.dnd-zone{
  border:2px dashed #c8d8b4;border-radius:16px;
  padding:14px 16px;min-height:130px;
  background:#f8faf4;transition:all .2s;
  display:flex;flex-direction:column;
}
.dnd-zone.drag-over{border-color:var(--green-d);background:#eef7e4;border-style:solid;}
.dnd-zone-label{
  font-size:.8rem;font-weight:700;color:var(--text-l);
  text-align:center;margin-bottom:10px;letter-spacing:.4px;
}
.dnd-arrow{
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;color:var(--text-l);
}
.dnd-zone-pills{
  flex:1;display:flex;flex-wrap:wrap;
  gap:8px;align-items:center;justify-content:center;
}
.dnd-empty-hint{
  font-size:.75rem;color:#c0c0b0;
  text-align:center;width:100%;line-height:1.6;
}
.row-pool-label{
  font-size:.78rem;font-weight:700;color:var(--text-l);
  margin-bottom:10px;letter-spacing:.4px;
}
.row-pool{
  display:flex;flex-wrap:wrap;gap:8px;
  min-height:46px;padding:10px 12px;
  border:1.5px solid var(--border);border-radius:12px;
  background:#fff;transition:all .2s;
}
.row-pool.drag-over{border-color:var(--green-d);background:#f0f7e8;}
.row-pool.drag-over .dnd-pill.in-pool{opacity:.6;}
.dnd-pill{
  padding:8px 18px;border-radius:24px;
  font-size:.84rem;font-weight:700;
  cursor:grab;user-select:none;white-space:nowrap;
  transition:all .15s;border:2px solid transparent;flex-shrink:0;
}
.dnd-pill:active{cursor:grabbing;}
.dnd-pill.dragging{opacity:.3;transform:scale(.92);}
.dnd-pill.in-pool{background:var(--green-l);color:var(--green-t);border-color:#a8cc88;}
.dnd-pill.in-pool:hover{background:#b0cc98;transform:translateY(-2px);box-shadow:0 4px 10px rgba(79,126,53,.2);}
.dnd-pill.in-zone1{background:var(--green-l);color:var(--green-t);border-color:#a8cc88;}
.dnd-pill.in-zone1:hover{background:#b0cc98;transform:translateY(-2px);}
.dnd-pill.in-zone2{background:#dce8ff;color:#3a5ea8;border-color:#afc5f5;}
.dnd-pill.in-zone2:hover{background:#c8d8ff;transform:translateY(-2px);}

/* ══ S3: 드래그앤드롭 ══ */
#screen-words.active{display:flex;flex-direction:column;min-height:100vh;height:100vh;}
#screen-words .dnd-body{flex:1;overflow-y:auto;padding:14px 1.5vw 6px;display:flex;flex-direction:column;gap:10px;width:100%;}

/* 상단 현황 바 */
.status-bar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.sb-item{display:flex;align-items:center;gap:5px;padding:5px 11px;border-radius:20px;font-size:.78rem;font-weight:700;}
.sb-item.sang{background:var(--red-bg);color:var(--red);}
.sb-item.jung{background:var(--amber-bg);color:var(--amber);}
.sb-item.ha{background:var(--green-bg);color:var(--green);}
.sb-item .sb-num{font-size:1rem;font-weight:900;}
.sb-guide{font-size:.72rem;color:var(--text-l);margin-left:auto;white-space:nowrap;}
.sb-warn{font-size:.72rem;color:#c0392b;font-weight:600;white-space:nowrap;}

/* 칸반 보드 */
.kanban{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;flex:1;min-height:0;}

/* 컬럼 */
.kb-col{
  background:#f7f5ef;border-radius:18px;
  border:2px solid var(--border);
  display:flex;flex-direction:column;
  min-height:100px;overflow:hidden;
  transition:border-color .2s,box-shadow .2s;
  box-shadow:0 2px 8px rgba(0,0,0,.05);
}
.kb-col.drag-over{box-shadow:0 0 0 3px rgba(79,126,53,.3);border-color:var(--green-d);}
.kb-col.sang-col{border-top:4px solid var(--red);}
.kb-col.jung-col{border-top:4px solid var(--amber);}
.kb-col.ha-col  {border-top:4px solid var(--green);}
.kb-col.unassigned-col{border-top:4px solid #f39c12;background:#fffbf0;}
.kb-head{
  padding:11px 14px 9px;
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0;
  border-bottom:1px solid #f0ece0;
}
.kb-title{font-size:.85rem;font-weight:800;display:flex;align-items:center;gap:6px;letter-spacing:-.2px;}
.kb-count{font-size:.72rem;font-weight:700;padding:2px 8px;border-radius:20px;}
.kb-col.sang-col .kb-title{color:var(--red);}
.kb-col.jung-col .kb-title{color:var(--amber);}
.kb-col.ha-col   .kb-title{color:var(--green);}
.kb-col.sang-col .kb-count{background:var(--red-bg);color:var(--red);}
.kb-col.jung-col .kb-count{background:var(--amber-bg);color:var(--amber);}
.kb-col.ha-col   .kb-count{background:var(--green-bg);color:var(--green);}
.kb-need{font-size:.68rem;color:var(--text-l);font-weight:500;}
.kb-cards{flex:1;padding:10px 12px;display:grid;grid-template-columns:1fr 1fr;gap:7px;overflow-y:auto;align-content:start;}
.kb-cards::-webkit-scrollbar{width:3px;}
.kb-cards::-webkit-scrollbar-thumb{background:#ddd;border-radius:2px;}
.kb-empty{text-align:center;padding:20px 8px;color:#ccc;font-size:.72rem;letter-spacing:.3px;grid-column:1/-1;}

/* 단어 카드 */
.dcard{
  background:#fff;border:1.5px solid #e4dfd0;border-radius:12px;
  padding:10px 12px;
  display:flex;align-items:center;justify-content:space-between;
  cursor:grab;user-select:none;transition:all .15s;
  box-shadow:0 2px 6px rgba(0,0,0,.08);
}
.dcard:hover{border-color:var(--green-l);box-shadow:0 2px 8px rgba(0,0,0,.09);transform:translateY(-1px);}
.dcard:active{cursor:grabbing;transform:scale(.97);}
.dcard.dragging{opacity:.35;transform:scale(.95);box-shadow:none;}
.dcard.needs{border-color:#f39c12;background:#fffdf5;}
.dc-main{display:flex;align-items:baseline;gap:6px;flex:1;min-width:0;}
.dc-kr{font-size:.86rem;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.dc-sep{font-size:.68rem;color:#ccc;flex-shrink:0;}
.dc-jp{font-size:.78rem;color:var(--text-l);font-family:"Klee One","Noto Sans JP",sans-serif;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.dc-right{display:flex;align-items:center;gap:3px;flex-shrink:0;margin-left:6px;}
.dc-db{font-size:.58rem;font-weight:700;letter-spacing:.3px;padding:1px 5px;border-radius:6px;}
.dc-db.found{background:#edf9f2;color:#1a7d42;}
.dc-db.manual{background:#f2f2f2;color:#aaa;}
.dc-del{background:none;border:none;cursor:pointer;color:#ddd;font-size:.75rem;padding:2px 4px;transition:color .1s;line-height:1;border-radius:4px;}
.dc-del:hover{color:var(--red);background:#fdf1ef;}

/* 하단 고정 입력창 */
.bottom-input{background:#fff;border-top:1px solid var(--border);padding:14px 16px;display:flex;flex-direction:column;gap:10px;flex-shrink:0;}
.bi-row{display:flex;gap:8px;align-items:stretch;}
.tinput{flex:1;padding:10px 13px;border:1.5px solid var(--border);border-radius:12px;font-size:.86rem;font-family:inherit;background:var(--bg);color:var(--text);transition:border-color .15s;}
.tinput:focus{outline:none;border-color:var(--green-d);background:#fff;}
.tinput::placeholder{color:#bbb;}

/* 업로드 존 */
.upload-zone{
  width:100%;border:2px dashed #b8d49a;border-radius:14px;
  padding:18px 14px 14px;text-align:center;cursor:pointer;
  transition:all .22s;background:rgba(198,220,168,.07);
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;
  position:relative;
}
.upload-zone:hover{border-color:var(--green-d);background:rgba(198,220,168,.18);}
.upload-zone.drag-active{border-color:var(--green-d);background:rgba(198,220,168,.28);transform:scale(1.01);}
.upload-icon{font-size:1.7rem;line-height:1;margin-bottom:2px;opacity:.75;transition:font-size .2s;}
.upload-main-txt{font-size:.85rem;font-weight:700;color:var(--green-t);transition:font-size .2s;}
.upload-sub-txt{font-size:.72rem;color:var(--text-l);transition:all .2s;}
.upload-format-txt{font-size:.68rem;color:#aaa;margin-top:2px;transition:all .2s;}
.upload-zone-footer{display:flex;align-items:center;justify-content:flex-end;gap:8px;margin-top:2px;}

/* 컴팩트 모드 (단어 있을 때 자동 축소) */
.upload-zone.compact{
  flex-direction:row;padding:7px 14px;gap:7px;
}
.upload-zone.compact .upload-icon{font-size:.95rem;margin-bottom:0;opacity:.55;}
.upload-zone.compact .upload-main-txt{font-size:.76rem;}
.upload-zone.compact .upload-sub-txt,
.upload-zone.compact .upload-format-txt{display:none;}
.word-count-badge{font-size:.72rem;color:var(--text-l);white-space:nowrap;}
.word-count-badge b{color:var(--green-d);}
.hint{font-size:.68rem;color:var(--text-l);}

/* ══ S4: 수행평가 툴 ══ */
#screen-tool{background:var(--bg);height:100vh;overflow:hidden;}
#screen-tool.active{display:flex;flex-direction:column;height:100vh;}
#screen-tool .hdr{flex-shrink:0;}
.tool-body{
  flex:1;display:flex;flex-direction:column;
  padding:2vh 8vw 10vh;gap:clamp(8px,1.5vh,16px);
  overflow-y:auto;min-height:0;
  max-width:1100px;margin:0 auto;width:100%;
}
/* 제목 */
.tool-title-wrap{text-align:center;margin-bottom:.5vh;}
.tool-title{font-size:clamp(1.5rem,4vw,3.2rem);font-weight:900;color:var(--text);display:block;font-family:"Jeju Gothic",sans-serif;letter-spacing:-1px;}
/* 문제 블록 */
.question-block{
  background:var(--card);border-radius:16px;
  padding:1.5vh 3vw;box-shadow:0 2px 12px rgba(0,0,0,.08);
  flex:1;display:flex;flex-direction:column;justify-content:center;
}
.question-block.q1-block{flex:0.9;}
.q-title-row{display:flex;align-items:center;flex-wrap:wrap;gap:clamp(8px,1.5vw,14px);}
/* Q 번호 레이블 */
.q-label{
  display:inline-flex;align-items:center;justify-content:center;
  width:clamp(34px,4vw,48px);height:clamp(34px,4vw,48px);min-width:clamp(34px,4vw,48px);
  background:#fff;border-radius:8px;border:2px solid var(--green-l);
  font-weight:900;font-size:clamp(1rem,2vw,1.35rem);
  color:var(--green-t);flex-shrink:0;
}
/* 지시문 */
.q-instruction{
  font-size:clamp(0.95rem,2vw,1.5rem);font-weight:700;color:var(--text);
  line-height:1.5;display:inline;white-space:normal;
}
/* 행 배지 (인라인 알약형) */
.row-badge-inline{
  background:var(--green-l);color:var(--green-t);
  border-radius:36px;
  min-width:clamp(72px,10vw,120px);height:clamp(46px,7vw,72px);
  display:inline-flex;align-items:center;justify-content:center;
  font-weight:700;font-size:clamp(1rem,2.5vw,1.8rem);
  white-space:nowrap;flex-shrink:0;overflow:hidden;
  padding:0 clamp(12px,2vw,22px);
  text-align:center;word-break:keep-all;line-height:1.2;
}
.row-badge-inline.long{font-size:clamp(0.9rem,1.8vw,1.3rem);white-space:normal;padding:0 clamp(10px,1.5vw,18px);}
/* 단어 그리드 */
.word-grid{
  display:grid;grid-template-columns:repeat(5,1fr);
  gap:1.2vw;margin-top:1vh;flex:1;
}
.word-grid.cols-4{grid-template-columns:repeat(4,1fr);}
.word-grid.cols-3{grid-template-columns:repeat(3,1fr);}
.word-grid.cols-2{grid-template-columns:repeat(2,1fr);}
.word-card-wrap{display:flex;flex-direction:column;align-items:center;gap:4px;height:100%;}
.word-num{
  font-size:clamp(1rem,1.8vw,1.3rem);color:var(--green-t);
  display:flex;align-items:center;justify-content:center;
  font-weight:600;flex-shrink:0;
}
.word-card{
  border:2px solid #b0cc98;border-radius:14px;
  background:var(--green-l);display:flex;
  align-items:center;justify-content:center;
  width:100%;padding:1.5vh 1vw;
  flex:1;min-height:6vh;max-height:16vh;
}
.word-korean{
  font-size:clamp(1.1rem,2.8vw,2rem);font-weight:700;
  color:var(--green-t);line-height:1.2;text-align:center;
}
.blank-badge{color:transparent !important;}
/* Click Here 버튼 */
.click-here-btn{
  align-self:center;
  padding:1.2vh 6vw;border:none;border-radius:1.2vw;
  background:var(--green-l);color:var(--green-t);
  font-size:clamp(0.9rem,1.8vw,1.1rem);font-weight:700;font-family:inherit;
  cursor:pointer;box-shadow:0 4px 16px rgba(0,0,0,.12);
  transition:background .15s;
  position:fixed;bottom:2.5vh;left:50%;transform:translateX(-50%);
  z-index:100;
}
.click-here-btn:hover{background:#b0cc98;}


/* ══ 반응형 ══ */
/* 태블릿 (768~1200px) */
@media(max-width:1200px){
  .hdr{padding:0 12px;gap:7px;}
  .tool-title{font-size:clamp(1.4rem,5vw,3.2rem);}
  .q-label{width:clamp(28px,3.5vw,44px);height:clamp(28px,3.5vw,44px);min-width:clamp(28px,3.5vw,44px);}
  .row-badge-inline{min-width:clamp(60px,9vw,110px);height:clamp(40px,6vw,64px);}
  .word-grid{gap:.8vw;}
}

/* 모바일/핸드폰 (≤768px) */
@media(max-width:768px){
  /* 헤더 반응형 */
  .hdr{padding:0 10px;gap:6px;}
  .hdr .brand{font-size:0.9rem;}
  .hdr .step{display:none;}
  /* 헤더 내 버튼 (inline style 덮어쓰기) */
  .hdr .btn{font-size:.68rem !important;padding:4px 8px !important;}

