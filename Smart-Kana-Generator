// zone1 = 선택1 행들, zone2 = 선택2 행들
let zone1Rows=[]; // 인덱스 배열
let zone2Rows=[]; // 인덱스 배열

function initZones(type){
  zone1Rows=[];
  zone2Rows=[];
  ST.selRows=[];
  renderZones();
}

function getPoolRows(){
  const rows=ROWS[ST.script];
  return rows.map((_,i)=>i).filter(i=>!zone1Rows.includes(i)&&!zone2Rows.includes(i));
}

function renderZones(){
  const rows=ROWS[ST.script];
  const z1=document.getElementById("zone1-pills");
  const z2=document.getElementById("zone2-pills");
  const pool=document.getElementById("row-pool");
  if(!z1||!z2||!pool)return;

  z1.innerHTML=zone1Rows.length
    ? zone1Rows.map(i=>pillHTML(i,"zone1")).join("")
    : "<span class='dnd-empty-hint'>여기에 행을 놓으세요</span>";

  z2.innerHTML=zone2Rows.length
    ? zone2Rows.map(i=>pillHTML(i,"zone2")).join("")
    : "<span class='dnd-empty-hint'>여기에 행을 놓으세요</span>";

  const poolRows=getPoolRows();
  pool.innerHTML=poolRows.length
    ? poolRows.map(i=>pillHTML(i,"pool")).join("")
    : "<span class='dnd-empty-hint' style='color:#bbb'>모든 행이 배치됨</span>";

  ST.selRows=zone1Rows;
  updateRowInfo();
}

function pillHTML(idx,zone){
  const rows=ROWS[ST.script];
  let cls;
  if(zone==="zone1") cls="in-zone1";
  else if(zone==="zone2") cls="in-zone2";
  else cls="in-pool";
  return `<span class="dnd-pill ${cls}"
    draggable="true"
    ondragstart="onPillDragStart(event,${idx},'${zone}')"
    ondragend="onPillDragEnd(event)"
  >${rows[idx].ko}</span>`;
}

// ── 드래그 이벤트 ──
let _dragSrc=null;

function onPillDragStart(e,idx,fromZone){
  _dragSrc={idx,fromZone};
  e.dataTransfer.effectAllowed="move";
  const el=e.target;
  setTimeout(()=>{ if(el)el.classList.add("dragging"); },0);
}
function onPillDragEnd(e){
  if(e.target)e.target.classList.remove("dragging");
  document.querySelectorAll(".dnd-zone,.row-pool").forEach(el=>el.classList.remove("drag-over"));
}
function onZoneDragOver(e){
  e.preventDefault();
  e.currentTarget.classList.add("drag-over");
}
function onZoneDragLeave(e){
  e.currentTarget.classList.remove("drag-over");
}
function onZoneDrop(e,toZone){
  e.preventDefault();
  try{e.currentTarget.classList.remove("drag-over");}catch(err){}
  if(!_dragSrc)return;
  const{idx,fromZone}=_dragSrc;
  _dragSrc=null;
  if(fromZone===toZone)return;
  // 원본에서 제거
  if(fromZone==="zone1")zone1Rows=zone1Rows.filter(i=>i!==idx);
  else if(fromZone==="zone2")zone2Rows=zone2Rows.filter(i=>i!==idx);
  // 목적지에 추가
  if(toZone==="zone1")zone1Rows=[...zone1Rows,idx].sort((a,b)=>a-b);
  else if(toZone==="zone2")zone2Rows=[...zone2Rows,idx].sort((a,b)=>a-b);
  renderZones();autoSave();
}
function updateRowInfo(){
  const rows=ROWS[ST.script];
  const box=document.getElementById("row-info-box");
  if(!box)return;
  const ok1=zone1Rows.length>0, ok2=zone2Rows.length>0;
  if(ok1&&ok2){
    const z1names=zone1Rows.map(i=>rows[i].ko).join(", ");
    const z2names=zone2Rows.map(i=>rows[i].ko).join(", ");
    box.innerHTML=`<strong style="color:var(--green-t);">선택1:</strong> ${z1names} &nbsp;|&nbsp; <strong style="color:#3a5ea8;">선택2:</strong> ${z2names}`;
    box.style.background="var(--green-bg)";box.style.borderColor="#a9dfbf";box.style.color="var(--text)";
  } else {
    box.innerHTML="⚠️ 선택 1과 선택 2에 각 1개 이상의 행을 배치해 주세요.";
    box.style.background="var(--amber-bg)";box.style.borderColor="#f9e4a0";box.style.color="var(--amber)";
  }
}
function changeCount(key,delta){
  const t=ST.counts.sang+ST.counts.jung+ST.counts.ha;
  if(delta<0&&t<=1)return;
  ST.counts[key]=Math.max(0,Math.min(8,ST.counts[key]+delta));
  document.getElementById("val-"+key).textContent=ST.counts[key];
  updateTotal(); autoSave();
}
function updateTotal(){document.getElementById("total-count").textContent=ST.counts.sang+ST.counts.jung+ST.counts.ha;}
function goToWords(){
  if(!zone1Rows.length||!zone2Rows.length){alert("각 구역에 행을 1개 이상 배치해 주세요.");return;}
  try{
    ["sang","jung","ha"].forEach(d=>{
      const el1=document.getElementById("need-"+d);
      const el2=document.getElementById("kn-"+d);
      if(el1)el1.textContent=ST.counts[d];
      if(el2)el2.textContent=ST.counts[d];
    });
    renderKanban();
    updateStatus();
  }catch(e){console.error("goToWords 에러:",e);}
  goScreen("screen-words");
}

// S3 드래그앤드롭
let dragIdx = null;

// 히라가나 → 한국어 역방향 맵 생성
const JP_TO_KR = {};
Object.entries(VOCAB_DB).forEach(([kr, arr])=>{
  arr.forEach(entry=>{ if(!JP_TO_KR[entry.jp]) JP_TO_KR[entry.jp]={kr, d:entry.d}; });
});

function isJapanese(str){
  return /[\u3040-\u309F\u30A0-\u30FF]/.test(str);
}

function lookupInput(input){
  const key=input.trim();
  if(isJapanese(key)){
    // 히라가나/가타카나 입력 → DB에서 한국어 찾기
    if(JP_TO_KR[key]){
      const {kr, d}=JP_TO_KR[key];
      return {kr, jp:key, diff:D_MAP[d]||"jung", fromDB:true};
    }
    // DB 없으면 jp=input, kr=null
    return {kr:null, jp:key, diff:null, fromDB:false};
  } else {
    // 한국어 입력 → DB에서 히라가나 찾기 (완전 일치 우선, 없으면 부분 일치)
    if(VOCAB_DB[key]){
      const entry=VOCAB_DB[key][0];
      return {kr:key, jp:entry.jp, diff:D_MAP[entry.d]||"jung", fromDB:true};
    }
    // 부분 일치: DB 키가 입력값을 포함하는 경우 (입력 2자 이상일 때만)
    if(key.length >= 2){
      const partialKey = Object.keys(VOCAB_DB).find(k => k.includes(key));
      if(partialKey){
        const entry=VOCAB_DB[partialKey][0];
        return {kr:partialKey, jp:entry.jp, diff:D_MAP[entry.d]||"jung", fromDB:true};
      }
    }
    return {kr:key, jp:null, diff:null, fromDB:false};
  }
}

// 기존 호환용
function lookupKr(kr){
  const r=lookupInput(kr);
  return {diff:r.diff, fromDB:r.fromDB};
}

function addWord(){
  const inp=document.getElementById("word-input");
  const raw=inp.value.trim(); if(!raw)return;
  raw.split(/[,，、\s]+/).map(w=>w.trim()).filter(Boolean).forEach(input=>{
    if(!input)return;
    const r=lookupInput(input);
    // 중복 체크: kr 기준 (가나 입력 시 kr이 같으면 스킵)
    if(ST.words.find(w=>w.kr===r.kr&&r.kr))return;
    if(ST.words.find(w=>w.jp===r.jp&&r.jp&&!r.kr))return;
    ST.words.push({kr:r.kr, jp:r.jp, diff:r.diff, fromDB:r.fromDB});
  });
  inp.value=""; renderKanban(); updateStatus(); autoSave();
}

function handleXlFile(file){
  if(!file)return;
  const reader=new FileReader();
  reader.onload=ev=>{
    const wb=XLSX.read(ev.target.result,{type:"binary"});
    const rows=XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]],{header:1});
    const colDiff=["sang","jung","ha"];
    rows.forEach(row=>{
      for(let col=0;col<3;col++){
        const val=row[col]; if(!val)continue;
        const input=String(val).trim();
        if(!input||["A","B","C","상","중","하"].includes(input))continue;
        const r=lookupInput(input);
        if(ST.words.find(w=>w.kr===r.kr&&r.kr))continue;
        ST.words.push({kr:r.kr, jp:r.jp, diff:colDiff[col], fromDB:r.fromDB});
      }
    });
    renderKanban(); updateStatus(); autoSave();
  };
  reader.readAsBinaryString(file);
  const inp=document.getElementById("xl-input"); if(inp)inp.value="";
}
function handleXlDrop(e){
  e.preventDefault();
  const file=e.dataTransfer.files[0];
  if(!file)return;
  if(!/\.(xlsx|xls)$/i.test(file.name)){alert("엑셀 파일(.xlsx, .xls)만 업로드할 수 있어요.");return;}
  handleXlFile(file);
}

function delWord(idx){ST.words.splice(idx,1);renderKanban();updateStatus();autoSave();}
function clearWords(){if(!confirm("모든 단어를 삭제할까요?"))return;ST.words=[];renderKanban();updateStatus();autoSave();}

function renderKanban(){
  document.getElementById("word-count").textContent=ST.words.length;
  // 단어가 있으면 업로드 존 컴팩트 모드
  const uz=document.getElementById("upload-zone");
  if(uz){uz.classList.toggle("compact",ST.words.length>0);}
  const groups={sang:[],jung:[],ha:[],null:[]};
  ST.words.forEach((w,i)=>{ const k=w.diff||"null"; (groups[k]=groups[k]||[]).push({...w,i}); });

  ["sang","jung","ha"].forEach(d=>{
    const c=document.getElementById("cards-"+d);
    const kc=document.getElementById("kc-"+d);
    if(c) c.innerHTML=groups[d].length
      ? groups[d].map(w=>cardHTML(w)).join("")
      : `<div class="kb-empty">여기에 드래그하세요</div>`;
    if(kc) kc.textContent=groups[d].length;
  });

  // 미분류
  const unList=groups["null"]||[];
  const wrap=document.getElementById("unassigned-wrap");
  wrap.style.display=unList.length?"block":"none";
  if(unList.length){
    document.getElementById("cards-unassigned").innerHTML=unList.map(w=>cardHTML(w)).join("");
    document.getElementById("kc-unassigned").textContent=unList.length;
  }
}

function cardHTML(w){
  const kr = w.kr || "";
  const jp = w.jp || "";
  const label = kr || jp || "?";
  return `<div class="dcard${!w.diff?" needs":""}" draggable="true"
    ondragstart="onDragStart(event,${w.i})"
    ondragend="onDragEnd(event)">
    <div class="dc-main">
      <span class="dc-kr">${label}</span>
      ${kr && jp ? `<span class="dc-sep">·</span><span class="dc-jp">${jp}</span>` : ""}
    </div>
    <div class="dc-right">
      <span class="dc-db ${w.fromDB?"found":"manual"}">${w.fromDB?"DB":""}</span>
      <button class="dc-del" onclick="delWord(${w.i})">✕</button>
    </div>
  </div>`;
}
function onDragStart(e,idx){dragIdx=idx;setTimeout(()=>e.target.classList.add("dragging"),0);}
function onDragEnd(e){e.target.classList.remove("dragging");document.querySelectorAll(".kb-col").forEach(c=>c.classList.remove("drag-over"));}
function onDragOver(e,diff){e.preventDefault();const id=diff?"col-"+diff:"col-unassigned";document.getElementById(id).classList.add("drag-over");}
function onDragLeave(e){e.currentTarget.classList.remove("drag-over");}
function onDrop(e,diff){
  e.preventDefault();e.currentTarget.classList.remove("drag-over");
  if(dragIdx===null)return;
  ST.words[dragIdx].diff=diff;
  dragIdx=null; renderKanban(); updateStatus(); autoSave();
}

function updateStatus(){
  const sang=ST.words.filter(w=>w.diff==="sang").length;
  const jung=ST.words.filter(w=>w.diff==="jung").length;
  const ha  =ST.words.filter(w=>w.diff==="ha").length;
  const noDiff=ST.words.filter(w=>!w.diff).length;
  document.getElementById("st-sang").textContent=sang;
  document.getElementById("st-jung").textContent=jung;
  document.getElementById("st-ha").textContent=ha;

  const warns=[];
  if(noDiff>0)warns.push(`⚠️ 미설정 ${noDiff}개`);
  if(sang<ST.counts.sang)warns.push(`🔴 상 부족(${sang}/${ST.counts.sang})`);
  if(jung<ST.counts.jung)warns.push(`🟠 중 부족(${jung}/${ST.counts.jung})`);
  if(ha<ST.counts.ha)warns.push(`🟢 하 부족(${ha}/${ST.counts.ha})`);

  const warnEl=document.getElementById("status-warn");
  const guideEl=document.getElementById("status-guide");
  if(warns.length){warnEl.textContent=warns.join(" · ");warnEl.style.display="";guideEl.style.display="none";}
  else{warnEl.style.display="none";guideEl.style.display="";}

  document.getElementById("tool-btn").disabled=!(!noDiff&&sang>=ST.counts.sang&&jung>=ST.counts.jung&&ha>=ST.counts.ha);
}

// 랜덤 생성
function pick(arr,n){const a=[...arr],r=[];while(r.length<n&&a.length){const i=Math.floor(Math.random()*a.length);r.push(a.splice(i,1)[0]);}return r;}
function shuffle(arr){const a=[...arr];for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
function buildRandom(){
  const rows=ROWS[ST.script];
  if(!zone1Rows.length||!zone2Rows.length)return;
  ST.row1=rows[zone1Rows[Math.floor(Math.random()*zone1Rows.length)]];
  ST.row2=rows[zone2Rows[Math.floor(Math.random()*zone2Rows.length)]];

  const total=ST.counts.sang+ST.counts.jung+ST.counts.ha;

  // diff 분류된 단어로 먼저 시도
  const sangPool=ST.words.filter(w=>w.diff==="sang");
  const jungPool=ST.words.filter(w=>w.diff==="jung");
  const haPool  =ST.words.filter(w=>w.diff==="ha");
  // 하→중→상 순서 (쉬운 단어에서 어려운 단어로)
  const picked=[
    ...pick(haPool,   Math.min(ST.counts.ha,   haPool.length)),
    ...pick(jungPool, Math.min(ST.counts.jung, jungPool.length)),
    ...pick(sangPool, Math.min(ST.counts.sang, sangPool.length)),
  ];

  if(picked.length>=total){
    // 정상: 분류된 단어가 충분
    ST.selWords=picked;
  } else if(ST.words.length>0){
    // 폴백: 분류 없이 전체 단어에서 랜덤 추출
    const usedKr=new Set(picked.map(w=>w.kr));
    const remaining=shuffle(ST.words.filter(w=>!usedKr.has(w.kr)));
    ST.selWords=shuffle([...picked,...remaining]).slice(0,Math.min(total,ST.words.length));
  } else {
    ST.selWords=[];
  }
}



// S4
const WORD_NUMS = ['①','②','③','④','⑤','⑥','⑦','⑧'];

function goToTool(){
  try{buildRandom();buildTool();}catch(e){console.error("goToTool 에러:",e);}
  goScreen("screen-tool");
}
function reGenerate(){buildRandom();reveal();}

function buildTool(){
  // Q1 배지 — 빈칸
  document.getElementById("q1-badges-inline").innerHTML=
    `<span class="row-badge-inline blank-badge">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
     <span class="row-badge-inline blank-badge">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>`;

  // Q2 단어 그리드 — 빈 카드
  const gridEl=document.getElementById("words-row");
  const total=ST.counts.sang+ST.counts.jung+ST.counts.ha;
  gridEl.innerHTML="";
  gridEl.className="word-grid";
  if(total<=2)gridEl.classList.add("cols-2");
  else if(total===3)gridEl.classList.add("cols-3");
  else if(total===4)gridEl.classList.add("cols-4");

  for(let i=0;i<total;i++){
    const wrap=document.createElement("div");
    wrap.className="word-card-wrap";
    wrap.innerHTML=`
      <div class="word-num">${WORD_NUMS[i]||i+1}</div>
      <div class="word-card" id="wc${i}"><div class="word-korean"></div></div>`;
    gridEl.appendChild(wrap);
  }
  const btn=document.getElementById("reveal-btn");
  btn.textContent="Click Here";
  btn.onclick=reveal;
}

function reveal(){
  if(!ST.row1||!ST.row2){buildRandom();}
  // Q1 배지 채우기
  const r1=ST.row1.ko||"";
  const r2=ST.row2.ko||"";
  document.getElementById("q1-badges-inline").innerHTML=
    `<span class="row-badge-inline ${r1.length>2?'long':''}">${r1}</span>
     <span class="row-badge-inline ${r2.length>2?'long':''}">${r2}</span>`;

  // Q2 단어 채우기
  const total=ST.counts.sang+ST.counts.jung+ST.counts.ha;
  ST.selWords.slice(0,total).forEach((w,i)=>{
    const el=document.getElementById("wc"+i);
    if(el){el.querySelector(".word-korean").textContent=w.kr||w.jp||"?";}
  });
  const btn=document.getElementById("reveal-btn");
  btn.textContent="🔀 다시 생성";
  btn.onclick=reGenerate;
}


// ══ 저장 / 불러오기 ══
const SAVE_KEY="jpn_tool_save";

function autoSave(){
  try{
    const data={
      script:ST.script,
      zone1:zone1Rows,
      zone2:zone2Rows,
      counts:ST.counts,
      words:ST.words,
      savedAt:new Date().toLocaleString("ko-KR")
    };
    localStorage.setItem(SAVE_KEY,JSON.stringify(data));
  }catch(e){}
}

function initSaveBanner(){
  try{
    const raw=localStorage.getItem(SAVE_KEY);
    if(!raw)return;
    const d=JSON.parse(raw);
    const banner=document.getElementById("save-banner");
    const info=document.getElementById("save-info-area");
    const scriptLabel=d.script==="hiragana"?"히라가나":"가타카나";
    const wc=d.words?d.words.length:0;
    const rows=ROWS[d.script]||ROWS["hiragana"];
    const z1names=(d.zone1||[]).map(i=>rows[i]?.ko||"").join(", ");
    const z2names=(d.zone2||[]).map(i=>rows[i]?.ko||"").join(", ");
    info.innerHTML=`
      <div class="save-info-row"><b>문자:</b> ${scriptLabel}</div>
      <div class="save-info-row"><b>①행:</b> ${z1names} &nbsp;|&nbsp; <b>②행:</b> ${z2names}</div>
      <div class="save-info-row"><b>단어:</b> ${wc}개
        <span class="sbadge">상 ${d.counts?.sang||0}</span>
        <span class="sbadge">중 ${d.counts?.jung||0}</span>
        <span class="sbadge">하 ${d.counts?.ha||0}</span>
      </div>
      <div class="save-info-row" style="color:var(--text-l);font-size:.74rem;">💾 ${d.savedAt||""}</div>`;
    banner.style.display="block";
  }catch(e){}
}

function loadSavedState(){
  try{
    const raw=localStorage.getItem(SAVE_KEY);
    if(!raw)return;
    const d=JSON.parse(raw);
    ST.script=d.script||"hiragana";
    zone1Rows=d.zone1||[];
    zone2Rows=d.zone2||[];
    ST.counts=d.counts||{sang:1,jung:2,ha:1};
    ST.words=d.words||[];
    // UI 동기화
    const scriptLabel=ST.script==="hiragana"?"히라가나":"가타카나";
    const setTxt2=(id,v)=>{const el=document.getElementById(id);if(el)el.textContent=v;};
    setTxt2("settings-lbl",scriptLabel+" 설정");
    setTxt2("q1-script-label",scriptLabel);
    setTxt2("tool-title-h1",scriptLabel+" 쓰기");
    setTxt2("q2-text","다음 단어에 해당하는 일본어를 "+scriptLabel+"로 쓰시오.");
    document.getElementById("q1-instruction").innerHTML=
      scriptLabel+' <span id="q1-badges-inline"></span> 에 해당하는 글자를 쓰시오.';
    ["sang","jung","ha"].forEach(key=>{
      document.getElementById("val-"+key).textContent=ST.counts[key];
      document.getElementById("need-"+key).textContent=ST.counts[key];
      document.getElementById("kn-"+key).textContent=ST.counts[key];
    });
    updateTotal();
    renderZones();
    renderKanban(); updateStatus();
    // 수행평가 툴로 바로 이동
    goToTool();
  }catch(e){alert("저장된 데이터를 불러오는 데 실패했어요.");}
}

function clearSavedState(){
  if(!confirm("저장된 설정을 삭제할까요?"))return;
  localStorage.removeItem(SAVE_KEY);
  document.getElementById("save-banner").style.display="none";
}

