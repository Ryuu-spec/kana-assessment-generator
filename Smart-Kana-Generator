<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>가나비 — 히라가나·가타카나 수행평가</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700;900&family=Noto+Sans+JP:wght@400;700&display=swap');

  :root {
    --bg: #f5f2e8;
    --card: #ffffff;
    --green-light: #c8ddb0;
    --green-dark: #5a8a3c;
    --green-btn: #c8ddb0;
    --green-text: #4a7a32;
    --text: #2d2d2d;
    --border: #d0c9b0;
    --shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Noto Sans KR', sans-serif;
    background: var(--bg);
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* ── [해결책] 화면 전환을 opacity가 아닌 display로 명확히 분리 ── */
  .screen {
    display: none; /* 기본은 아예 존재하지 않음 */
    width: 100%;
    max-width: 600px;
    padding: 20px;
    flex-direction: column;
    align-items: center;
  }

  /* active 클래스가 붙은 단 하나의 화면만 물리적으로 나타남 */
  .screen.active {
    display: flex !important;
  }

  .card {
    background: var(--card);
    border-radius: 20px;
    padding: 40px;
    width: 100%;
    box-shadow: var(--shadow);
    text-align: center;
  }

  /* 버튼 클릭 영역 최적화 */
  .select-btn {
    flex: 1; padding: 30px 10px; border-radius: 16px;
    border: 2px solid var(--border); background: white;
    cursor: pointer; transition: 0.2s;
  }
  .select-btn:hover { border-color: var(--green-dark); background: #f4f9ef; }
  
  /* 버튼 내부 요소가 클릭을 방해하지 않도록 설정 */
  .select-btn * { pointer-events: none; }

  .row-btn {
    padding: 8px 15px; border-radius: 20px; border: 2px solid #ddd;
    background: white; cursor: pointer; font-weight: 700; margin: 4px;
  }
  .row-btn.selected { background: var(--green-btn); color: var(--green-text); border-color: var(--green-btn); }

  .btn-next {
    background: var(--green-btn); color: var(--green-text); border: none;
    border-radius: 10px; padding: 15px; font-size: 1.1rem; font-weight: 700;
    width: 100%; cursor: pointer; margin-top: 20px;
  }
</style>
</head>
<body>

<div id="select-screen" class="screen active">
  <div class="card">
    <h1 style="color:var(--green-dark); margin-bottom:10px;">가나비</h1>
    <p style="margin-bottom:30px; color:#666;">평가할 문자를 선택하세요</p>
    <div style="display:flex; gap:15px;">
      <button class="select-btn" onclick="goNext('hiragana')">
        <b style="font-size:2rem; display:block; color:var(--green-text);">あ</b>
        히라가나
      </button>
      <button class="select-btn" onclick="goNext('katakana')">
        <b style="font-size:2rem; display:block; color:var(--green-text);">ア</b>
        가타카나
      </button>
    </div>
  </div>
</div>

<div id="settings-screen" class="screen">
  <div class="card">
    <h3 style="margin-bottom:20px; text-align:left;">출제 행 선택</h3>
    <div id="row-container" style="text-align:left;"></div>
    <button class="btn-next" onclick="showScreen('upload-screen')">다음 단계 (파일 업로드)</button>
  </div>
</div>

<div id="upload-screen" class="screen">
  <div class="card">
    <h3>엑셀 파일 업로드</h3>
    <div style="border:2px dashed #ccc; padding:40px; margin:20px 0; border-radius:15px; cursor:pointer;" onclick="document.getElementById('file-input').click()">
      여기를 클릭하여 파일을 선택하세요
    </div>
    <input type="file" id="file-input" accept=".xlsx,.xls" style="display:none;" onchange="handleFile(this)">
    <div id="file-status" style="margin-bottom:10px; font-weight:bold; color:var(--green-dark);"></div>
    <button class="btn-next" id="gen-btn" disabled onclick="generate()">수행평가 생성</button>
  </div>
</div>

<div id="result-screen" class="screen" style="max-width:800px;">
  <div class="card" id="print-area" style="text-align:left;">
    <h1 style="text-align:center; border-bottom:2px solid #000; padding-bottom:10px;">일본어 수행평가</h1>
    <div id="q1-out" style="margin:20px 0;"></div>
    <div id="q2-out" style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;"></div>
    <button class="btn-next" onclick="window.print()">인쇄하기</button>
  </div>
</div>

<script>
const ROWS = ['아행','카행','사행','타행','나행','하행','마행','라행','야행+와행'];
let selRows = [];
let wordData = { sang:[], jung:[], ha:[] };

function showScreen(id) {
  // 모든 화면 숨기기
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  // 대상 화면만 보이기
  const target = document.getElementById(id);
  if(target) target.classList.add('active');
}

function goNext(type) {
  const container = document.getElementById('row-container');
  container.innerHTML = ROWS.map(r => `<button class="row-btn" onclick="toggleR(this,'${r}')">${r}</button>`).join('');
  showScreen('settings-screen');
}

function toggleR(btn, r) {
  btn.classList.toggle('selected');
  if(btn.classList.contains('selected')) selRows.push(r);
  else selRows = selRows.filter(v => v !== r);
}

function handleFile(input) {
  const file = input.files[0];
  const reader = new FileReader();
  reader.onload = function(e) {
    const data = new Uint8Array(e.target.result);
    const wb = XLSX.read(data, {type:'array'});
    const rows = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], {header:1});
    
    wordData = { sang:[], jung:[], ha:[] };
    rows.forEach(row => {
      if(row[0] && row[1]) {
        let lv = row[0].length <= 2 ? 'ha' : (row[0].length <= 4 ? 'jung' : 'sang');
        wordData[lv].push({w:row[0], m:row[1]});
      }
    });
    document.getElementById('file-status').textContent = "파일 준비 완료!";
    document.getElementById('gen-btn').disabled = false;
  };
  reader.readAsArrayBuffer(file);
}

function generate() {
  const q1 = selRows[0] || "아행";
  document.getElementById('q1-out').innerHTML = `<h3>1. 다음 행의 글자를 쓰시오: <b>${q1}</b></h3>`;
  
  const q2 = document.getElementById('q2-out');
  q2.innerHTML = '';
  const all = [...wordData.sang, ...wordData.jung, ...wordData.ha].sort(()=>.5-Math.random()).slice(0,4);
  
  all.forEach((w, i) => {
    q2.innerHTML += `<div style="border:1px solid #ddd; padding:10px;">${i+1}. ${w.m} ( &nbsp;&nbsp;&nbsp;&nbsp; )</div>`;
  });
  showScreen('result-screen');
}
</script>
</body>
</html>
