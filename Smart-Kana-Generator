<!-- ══ S2: 설정 ══ -->
<div id="screen-settings" class="screen">
  <div class="hdr">
    <span class="brand">일본어 문자 쓰기 수행평가 툴</span>
    <button class="btn btn-ol" style="font-size:.74rem;padding:5px 10px;border-color:rgba(255,255,255,.4);color:#fff;background:transparent;" onclick="goScreen('screen-select')">← 문자 선택</button>
    <span class="step" id="settings-lbl">설정</span>
  </div>
  <div class="cwrap" style="max-width:960px;margin:0 auto;width:100%;gap:12px;">

    <div class="card" style="width:100%;padding-bottom:16px;">
      <div class="ctitle"><span class="step-badge">1</span>행 범위 설정</div>
      <div style="font-size:.74rem;color:var(--text-l);margin-bottom:12px;">아래의 행 버튼을 드래그하여 원하는 위치에 놓아주세요</div>
      <div class="dnd-zones">
        <div class="dnd-zone" id="dnd-zone1"
          ondragover="onZoneDragOver(event)"
          ondrop="onZoneDrop(event,'zone1')"
          ondragleave="onZoneDragLeave(event)">
          <div class="dnd-zone-label">선택 1</div>
          <div class="dnd-zone-pills" id="zone1-pills"></div>
        </div>
        <div class="dnd-arrow">↔</div>
        <div class="dnd-zone" id="dnd-zone2"
          ondragover="onZoneDragOver(event)"
          ondrop="onZoneDrop(event,'zone2')"
          ondragleave="onZoneDragLeave(event)">
          <div class="dnd-zone-label">선택 2</div>
          <div class="dnd-zone-pills" id="zone2-pills"></div>
        </div>
      </div>
      <div class="row-pool-label">행 목록</div>
      <div class="row-pool" id="row-pool"
        ondragover="onZoneDragOver(event)"
        ondrop="onZoneDrop(event,'pool')"
        ondragleave="onZoneDragLeave(event)">
      </div>
      <div class="info-box" id="row-info-box" style="margin-top:10px;">선택 1과 선택 2에 각 1개 이상의 행을 배치해 주세요.</div>
    </div>

    <div class="card" style="width:100%;padding-bottom:16px;">
      <div class="ctitle"><span class="step-badge">2</span>난이도별 문항 수</div>
      <div class="stepper-row">
        <div class="sitem sang">
          <div class="slbl"><span class="dot sang"></span> 상</div>
          <div class="sctl">
            <button class="sbtn" onclick="changeCount('sang',-1)">−</button>
            <div class="sval" id="val-sang">1</div>
            <button class="sbtn" onclick="changeCount('sang',1)">+</button>
          </div>
        </div>
        <div class="sitem jung">
          <div class="slbl"><span class="dot jung"></span> 중</div>
          <div class="sctl">
            <button class="sbtn" onclick="changeCount('jung',-1)">−</button>
            <div class="sval" id="val-jung">2</div>
            <button class="sbtn" onclick="changeCount('jung',1)">+</button>
          </div>
        </div>
        <div class="sitem ha">
          <div class="slbl"><span class="dot ha"></span> 하</div>
          <div class="sctl">
            <button class="sbtn" onclick="changeCount('ha',-1)">−</button>
            <div class="sval" id="val-ha">1</div>
            <button class="sbtn" onclick="changeCount('ha',1)">+</button>
          </div>
        </div>
      </div>
      <div class="tnote" style="margin-top:10px;">총 단어 수: <b id="total-count">4</b>개</div>
    </div>

    <button class="btn btn-dark btn-full" style="padding:13px;width:100%;" onclick="goToWords()">다음 → 단어 입력</button>

  </div>
</div><!-- /screen-settings -->

<!-- ══ S3: 단어 입력 (드래그앤드롭) ══ -->
<div id="screen-words" class="screen">
  <div class="hdr">
    <span class="brand">일본어 문자 쓰기 수행평가 툴</span>
    <button class="btn btn-ol" style="font-size:.74rem;padding:5px 10px;border-color:rgba(255,255,255,.4);color:#fff;background:transparent;" onclick="goScreen('screen-settings')">← 설정</button>
    <span class="step">단어 입력</span>
  </div>
  <div class="dnd-body">
    <!-- 현황 바 -->
    <div class="status-bar">
      <div class="sb-item sang"><span class="sb-num" id="st-sang">0</span>/<span id="need-sang">1</span> 상</div>
      <div class="sb-item jung"><span class="sb-num" id="st-jung">0</span>/<span id="need-jung">2</span> 중</div>
      <div class="sb-item ha"  ><span class="sb-num" id="st-ha">0</span>/<span id="need-ha">1</span> 하</div>
      <span class="sb-guide" id="status-guide">💡 출제 수의 2배 이상 입력하면 반마다 다른 단어가 출제됩니다.</span>
      <span class="sb-warn" id="status-warn" style="display:none;"></span>
    </div>
    <!-- 칸반 -->
    <div class="kanban">
      <div class="kb-col sang-col" id="col-sang" ondragover="onDragOver(event,'sang')" ondragleave="onDragLeave(event)" ondrop="onDrop(event,'sang')">
        <div class="kb-head">
          <span class="kb-title">🔴 상</span>
